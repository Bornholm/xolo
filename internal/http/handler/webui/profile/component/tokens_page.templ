package component

import (
	"github.com/bornholm/xolo/internal/core/model"
	common "github.com/bornholm/xolo/internal/http/handler/webui/common/component"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/alert"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/button"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/card"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/dialog"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/icon"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/input"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/popover"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/selectbox"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/table"
)

type TokensPageVModel struct {
	AppLayoutVModel common.AppLayoutVModel
	AuthTokens      []model.AuthToken
	OrgMemberships  []model.Membership
	CreatedToken    string
	DeletedToken    bool
}

templ TokensPage(vmodel TokensPageVModel) {
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle("Clés API")) {
		<div class="space-y-6">
			<!-- Header -->
			<div class="flex items-start justify-between gap-4">
				<div>
					<h1 class="text-2xl font-semibold">Clés API</h1>
					<p class="text-sm text-muted-foreground">Authentifiez vos requêtes vers le proxy compatible OpenAI.</p>
				</div>
				@dialog.Trigger(dialog.TriggerProps{For: "token-create-dialog"}) {
					@button.Button(button.Props{Size: button.SizeSm}) {
						@icon.Plus(icon.Props{Class: "h-4 w-4 mr-2"})
						Nouvelle clé
					}
				}
			</div>
			if vmodel.DeletedToken {
				@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
					@alert.Description() {
						Clé API supprimée avec succès.
					}
				}
			}
			if vmodel.CreatedToken != "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
					@alert.Description() {
						<div class="font-medium">Clé API créée avec succès</div>
						<div class="text-sm mt-1">Copiez cette clé maintenant, elle ne sera plus affichée.</div>
						<div class="flex items-center gap-2 mt-2">
							<code class="flex-1 block bg-muted rounded-md px-3 py-2 text-sm font-mono break-all">{ vmodel.CreatedToken }</code>
							@button.Button(button.Props{
								Variant: button.VariantOutline,
								Size:    button.SizeSm,
								Class:   "shrink-0",
								Attributes: templ.Attributes{
									"type":     "button",
									"title":    "Copier",
									"data-url": vmodel.CreatedToken,
									"onclick":  "navigator.clipboard.writeText(this.dataset.url)",
								},
							}) {
								@icon.Copy(icon.Props{Class: "h-4 w-4 mr-2"})
								Copier
							}
						</div>
					}
				}
			}
			<!-- Auth Tokens Section -->
			if len(vmodel.AuthTokens) == 0 {
				<div class="rounded-lg border p-6 text-center text-muted-foreground">
					Aucune clé API configurée. Les clés API permettent d'utiliser les modèles exposés par Xolo depuis vos applications et outils habituels.
				</div>
			} else {
				@card.Card() {
					@card.Content() {
						@table.Table() {
							@table.Header() {
								@table.Head() {
									Nom
								}
								@table.Head() {
									Organisation
								}
								@table.Head() {
									Expiration
								}
								@table.Head(table.HeadProps{Class: "text-right"}) {
									Actions
								}
							}
							@table.Body() {
								for _, token := range vmodel.AuthTokens {
									@table.Row() {
										@table.Cell() {
											<span class="font-medium">{ token.Label() }</span>
										}
										@table.Cell(table.CellProps{Class: "text-muted-foreground"}) {
											{ tokenOrgName(token, vmodel.OrgMemberships) }
										}
										@table.Cell(table.CellProps{Class: "text-muted-foreground"}) {
											{ tokenExpiry(token) }
										}
										@table.Cell(table.CellProps{Class: "text-right"}) {
											@button.Button(button.Props{
												Variant: button.VariantGhost,
												Size:    button.SizeSm,
												Class:   "text-destructive hover:text-destructive",
												Attributes: templ.Attributes{
													"type":     "button",
													"data-url": common.BaseURLString(ctx, common.WithPath("/profile/tokens/", string(token.ID()))),
													"onclick":  "if(confirm('Supprimer cette clé API ? Cette action est irréversible.'))fetch(this.dataset.url,{method:'DELETE'}).then(r=>window.location.href=r.url)",
												},
											}) {
												@icon.Trash2(icon.Props{Size: 14, Class: "mr-2"})
												Révoquer
											}
										}
									}
								}
							}
						}
					}
				}
			}
		</div>
		<!-- Token Creation Dialog -->
		@dialog.Dialog(dialog.Props{ID: "token-create-dialog"}) {
			@dialog.Content() {
				@dialog.Header() {
					@dialog.Title(dialog.TitleProps{}) {
						Créer une clé API
					}
				}
				<div class="space-y-4">
					<div class="p-3 rounded-md bg-yellow-50 dark:bg-yellow-900/20 text-sm">
						<strong>Important :</strong> La clé API ne sera affichée qu'une seule fois après sa création. Assurez-vous de la copier dans un endroit sûr.
					</div>
					<form id="token-create-form" method="POST" action={ common.BaseURL(ctx, common.WithPath("/profile/tokens")) } class="space-y-4">
						<div class="space-y-2">
							<label for="token-label" class="text-sm font-medium">Nom de la clé</label>
							@input.Input(input.Props{
								Name:        "label",
								ID:          "token-label",
								Placeholder: "Ex: Application mobile, Script de sauvegarde...",
							})
						</div>
						<div class="space-y-2">
							<label for="token-org" class="text-sm font-medium">Organisation <span class="text-destructive">*</span></label>
							if len(vmodel.OrgMemberships) == 0 {
								<p class="text-sm text-muted-foreground">Vous n’appartenez à aucune organisation. Contactez un administrateur pour rejoindre une organisation avant de créer une clé API.</p>
							} else {
								@selectbox.SelectBox(selectbox.Props{ID: "token-org"}) {
									@selectbox.Trigger(selectbox.TriggerProps{
										Name:       "org_id",
										Attributes: templ.Attributes{"required": "required"},
									}) {
										@selectbox.Value(selectbox.ValueProps{Placeholder: "— Sélectionnez une organisation —"})
									}
									@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
										@selectbox.Group() {
											for _, m := range vmodel.OrgMemberships {
												if m.Org() != nil {
													@selectbox.Item(selectbox.ItemProps{Value: string(m.OrgID())}) {
														{ m.Org().Name() }
													}
												}
											}
										}
									}
								}
							}
						</div>
						<div class="space-y-2">
							<label for="token-expires" class="text-sm font-medium">Date d'expiration (optionnel)</label>
							@input.Input(input.Props{ID: "token-expires", Name: "expires_at", Type: input.TypeDate})
						</div>
					</form>
				</div>
				@dialog.Footer(dialog.FooterProps{}) {
					@button.Button(button.Props{
						Type:     button.TypeSubmit,
						Disabled: len(vmodel.OrgMemberships) == 0,
						Attributes: templ.Attributes{
							"onclick": "document.getElementById('token-create-form').requestSubmit()",
						},
					}) {
						Créer la clé
					}
				}
			}
		}
		<!-- Dialog Script -->
		@dialog.Script()
		@popover.Script()
		@selectbox.Script()
	}
}

func tokenOrgName(token model.AuthToken, memberships []model.Membership) string {
	if token.OrgID() == "" {
		return "—"
	}
	for _, m := range memberships {
		if m.OrgID() == token.OrgID() && m.Org() != nil {
			return m.Org().Name()
		}
	}
	return string(token.OrgID())
}

func tokenExpiry(token model.AuthToken) string {
	if token.ExpiresAt() == nil {
		return "—"
	}
	return token.ExpiresAt().Format("02/01/2006")
}
