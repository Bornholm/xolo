package component

import (
	"encoding/json"
	"fmt"
	"github.com/bornholm/xolo/internal/core/model"
	common "github.com/bornholm/xolo/internal/http/handler/webui/common/component"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/card"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/icon"
)

const DefaultMaxDisplayedModels int = 3

type ModelsPageVModel struct {
	AppLayoutVModel common.AppLayoutVModel
	ModelUsages     []ModelUsage
	Range           string
	RemainingCount  int
}

templ ModelsPage(vmodel ModelsPageVModel) {
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle("Modèles")) {
		<div class="space-y-6">
			<!-- Header + period selector -->
			<div class="flex items-center justify-between">
				<div class="flex items-center gap-4">
					@icon.BrainCircuit(icon.Props{Class: "h-8 w-8"})
					<h1 class="text-2xl font-semibold">Modèles</h1>
				</div>
				<form method="GET" class="flex items-center gap-2">
					<label class="text-sm text-muted-foreground">Période :</label>
					<select name="range" onchange="this.form.submit()" class="h-9 rounded-md border border-input bg-background px-3 text-sm">
						for _, opt := range []struct{ Value, Label string }{
							{"1d", "Dernier jour"},
							{"7d", "7 derniers jours"},
							{"30d", "30 derniers jours"},
							{"90d", "3 derniers mois"},
							{"180d", "6 derniers mois"},
							{"365d", "Dernière année"},
						} {
							if vmodel.Range == opt.Value || (vmodel.Range == "" && opt.Value == "7d") {
								<option value={ opt.Value } selected>{ opt.Label }</option>
							} else {
								<option value={ opt.Value }>{ opt.Label }</option>
							}
						}
					</select>
				</form>
			</div>
			<!-- Models grid -->
			if len(vmodel.ModelUsages) == 0 {
				<p class="text-sm text-muted-foreground">Aucun modèle disponible.</p>
			} else {
				<div class="space-y-4">
					<div id="models-grid" class="grid grid-cols-1 md:grid-cols-3 gap-4">
						{{ max := DefaultMaxDisplayedModels }}
						if vmodel.RemainingCount == 0 {
							{{ max = len(vmodel.ModelUsages) }}
						}
						for _, mu := range vmodel.ModelUsages[:max] {
							@card.Card() {
								@card.Header() {
									@card.Title() {
										if mu.Org != nil {
											{ mu.Org.Slug() + "/" + mu.Model.ProxyName() }
										} else {
											{ mu.Model.ProxyName() }
										}
										if mu.Model.IsVirtual() {
											<span class="ml-2 text-xs bg-primary/10 text-primary px-2 py-0.5 rounded">Virtuel</span>
										}
									}
									if mu.Org != nil {
										<p class="text-xs text-muted-foreground">{ mu.Org.Name() }</p>
									}
								}
								@card.Content() {
									<div class="space-y-3">
										if mu.Model.Description() != "" {
											<p class="text-sm text-muted-foreground">{ mu.Model.Description() }</p>
										}
										if !mu.Model.IsVirtual() {
											<div class="grid grid-cols-2 gap-2 text-sm">
												<div>
													<span class="text-muted-foreground">Prompt (1M tokens)</span>
													<p class="font-medium">{ formatCostPerM(mu.Model.PromptCostPer1KTokens(), orgCurrency(mu.Org)) }</p>
												</div>
												<div>
													<span class="text-muted-foreground">Complétion (1M tokens)</span>
													<p class="font-medium">{ formatCostPerM(mu.Model.CompletionCostPer1KTokens(), orgCurrency(mu.Org)) }</p>
												</div>
											</div>
										}
										if mu.Aggregate != nil && mu.Aggregate.TotalRequests > 0 {
											<div class="border-t pt-3 grid grid-cols-3 gap-2 text-sm">
												<div>
													<span class="text-muted-foreground">Requêtes</span>
													<p class="font-medium">{ fmt.Sprintf("%d", mu.Aggregate.TotalRequests) }</p>
												</div>
												<div>
													<span class="text-muted-foreground">Tokens</span>
													<p class="font-medium">{ fmt.Sprintf("%d", mu.Aggregate.TotalTokens) }</p>
												</div>
												<div>
													<span class="text-muted-foreground">Coût</span>
													<p class="font-medium">{ formatCost(mu.Aggregate.TotalCost, mu.Aggregate.Currency) }</p>
												</div>
											</div>
										}
									</div>
								}
							}
						}
					</div>
					if vmodel.RemainingCount > 0 {
						<a
							href={ common.BaseURL(ctx, common.WithPath("/models"), common.WithValues("show_all", "true")) }
							class="text-sm text-muted-foreground hover:text-foreground underline cursor-pointer"
						>
							Afficher { fmt.Sprintf("%d", vmodel.RemainingCount) } modèle(s) supplémentaire(s)
						</a>
					}
				</div>
			}
			<!-- How-to card -->
			@card.Card() {
				@card.Header() {
					@card.Title() {
						Accès à l'API
					}
					<p class="text-sm text-muted-foreground">Xolo expose une API compatible OpenAI. Utilisez les paramètres ci-dessous avec vos outils habituels.</p>
				}
				@card.Content() {
					<div class="space-y-4">
						<!-- Base URL -->
						<div class="space-y-1">
							<p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">URL de base</p>
							<div class="flex items-center gap-2">
								<code class="flex-1 block bg-muted rounded-md px-3 py-2 text-sm font-mono break-all">{ common.BaseURLString(ctx, common.WithPath("/api/v1")) }</code>
								<button
									type="button"
									title="Copier"
									data-url={ common.BaseURLString(ctx, common.WithPath("/api/v1")) }
									onclick="navigator.clipboard.writeText(this.dataset.url)"
									class="shrink-0 rounded-md p-2 hover:bg-muted transition-colors"
								>
									@icon.Copy(icon.Props{Class: "h-4 w-4"})
								</button>
							</div>
						</div>
						<!-- Auth + model name -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
							<div class="space-y-1">
								<p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Authentification</p>
								<p>En-tête HTTP <code class="bg-muted rounded px-1 text-xs">Authorization: Bearer &lt;clé-api&gt;</code></p>
								<p class="text-xs text-muted-foreground">Créez une clé API depuis <a href={ common.BaseURL(ctx, common.WithPath("/profile/tokens")) } class="underline">votre profil</a>.</p>
							</div>
							<div class="space-y-1">
								<p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Nom du modèle</p>
								<p>Format <code class="bg-muted rounded px-1 text-xs">&lt;organisation&gt;/&lt;modèle&gt;</code></p>
								<p class="text-xs text-muted-foreground">Le nom complet est affiché sur chaque carte ci-dessous.</p>
							</div>
						</div>
						<!-- Tool examples -->
						<div class="space-y-2">
							<p class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Exemples d'utilisation</p>
							<details class="group rounded-md border">
								<summary class="flex cursor-pointer items-center gap-2 px-3 py-2 text-sm font-medium select-none">
									@icon.Terminal(icon.Props{Class: "h-4 w-4 shrink-0"})
									curl
								</summary>
								<pre class="overflow-x-auto border-t bg-muted px-4 py-3 text-xs font-mono leading-relaxed">{ curlExample(common.BaseURLString(ctx, common.WithPath("/api/v1"))) }</pre>
							</details>
							<details class="group rounded-md border">
								<summary class="flex cursor-pointer items-center gap-2 px-3 py-2 text-sm font-medium select-none">
									@icon.Code(icon.Props{Class: "h-4 w-4 shrink-0"})
									Python · openai
								</summary>
								<pre class="overflow-x-auto border-t bg-muted px-4 py-3 text-xs font-mono leading-relaxed">{ pythonExample(common.BaseURLString(ctx, common.WithPath("/api/v1"))) }</pre>
							</details>
							<details class="group rounded-md border">
								<summary class="flex cursor-pointer items-center gap-2 px-3 py-2 text-sm font-medium select-none">
									@icon.Code(icon.Props{Class: "h-4 w-4 shrink-0"})
									OpenCode · ~/.config/opencode/config.json
								</summary>
								<pre class="overflow-x-auto border-t bg-muted px-4 py-3 text-xs font-mono leading-relaxed">{ openCodeConfigExample(common.BaseURLString(ctx, common.WithPath("/api/v1")), vmodel.ModelUsages) }</pre>
							</details>
						</div>
					</div>
				}
			}
		</div>
	}
}

func curlExample(baseURL string) string {
	return `curl ` + baseURL + `/chat/completions \
  -H "Authorization: Bearer <clé-api>" \
  -H "Content-Type: application/json" \
  -d '{
    "model": "<organisation>/<modèle>",
    "messages": [{"role": "user", "content": "Bonjour !"}]
  }'`
}

func pythonExample(baseURL string) string {
	return `from openai import OpenAI

client = OpenAI(
    base_url="` + baseURL + `",
    api_key="<clé-api>",
)

response = client.chat.completions.create(
    model="<organisation>/<modèle>",
    messages=[{"role": "user", "content": "Bonjour !"}],
)
print(response.choices[0].message.content)`
}

func openCodeConfigExample(baseURL string, modelUsages []ModelUsage) string {
	type modelLimit struct {
		Context int64 `json:"context,omitempty"`
		Output  int64 `json:"output,omitempty"`
	}
	type modelEntry struct {
		Name  string      `json:"name"`
		Limit *modelLimit `json:"limit,omitempty"`
	}
	type providerOptions struct {
		BaseURL string `json:"baseURL"`
		APIKey  string `json:"apiKey"`
	}
	type providerEntry struct {
		NPM     string                `json:"npm"`
		Name    string                `json:"name"`
		Options providerOptions       `json:"options"`
		Models  map[string]modelEntry `json:"models"`
	}
	type configRoot struct {
		Schema   string                   `json:"$schema"`
		Provider map[string]providerEntry `json:"provider"`
	}

	models := make(map[string]modelEntry)
	for _, mu := range modelUsages {
		var name string
		if mu.Org != nil {
			name = mu.Org.Slug() + "/" + mu.Model.ProxyName()
		} else {
			name = mu.Model.ProxyName()
		}

		entry := modelEntry{Name: name}

		if ctx := mu.Model.ContextWindow(); ctx > 0 {
			if entry.Limit == nil {
				entry.Limit = &modelLimit{}
			}
			entry.Limit.Context = ctx
		}
		if out := mu.Model.OutputWindow(); out > 0 {
			if entry.Limit == nil {
				entry.Limit = &modelLimit{}
			}
			entry.Limit.Output = out
		}

		models[name] = entry
	}

	cfg := configRoot{
		Schema: "https://opencode.ai/config.json",
		Provider: map[string]providerEntry{
			"xolo": {
				NPM:  "@ai-sdk/openai-compatible",
				Name: "Xolo",
				Options: providerOptions{
					BaseURL: baseURL,
					APIKey:  "{env:XOLO_API_KEY}",
				},
				Models: models,
			},
		},
	}

	data, err := json.MarshalIndent(cfg, "", "  ")
	if err != nil {
		return ""
	}
	return string(data)
}

func formatCostPerM(microcentsPer1K int64, currency string) string {
	return formatCostPerMCurrency(currency, microcentsPer1K*1000)
}

func formatCostPerMCurrency(currency string, microcents int64) string {
	symbol := "$"
	switch currency {
	case "EUR":
		symbol = "€"
	case "GBP":
		symbol = "£"
	case "JPY":
		symbol = "¥"
	}
	return fmt.Sprintf("%.6f%s", float64(microcents)/1_000_000, symbol)
}

func orgCurrency(org model.Organization) string {
	if org == nil {
		return "USD"
	}
	currency := org.Currency()
	if currency == "" {
		return "USD"
	}
	return currency
}

templ ModelsGrid(modelUsages []ModelUsage) {
	<div id="models-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4">
		for _, mu := range modelUsages {
			@card.Card() {
				@card.Header() {
					@card.Title() {
						if mu.Org != nil {
							{ mu.Org.Slug() + "/" + mu.Model.ProxyName() }
						} else {
							{ mu.Model.ProxyName() }
						}
					}
					if mu.Org != nil {
						<p class="text-xs text-muted-foreground">{ mu.Org.Name() }</p>
					}
				}
				@card.Content() {
					<div class="space-y-3">
						if mu.Model.Description() != "" {
							<p class="text-sm text-muted-foreground">{ mu.Model.Description() }</p>
						}
						<div class="grid grid-cols-2 gap-2 text-sm">
							<div>
								<span class="text-muted-foreground">Prompt (1M tokens)</span>
								<p class="font-medium">{ formatCostPerM(mu.Model.PromptCostPer1KTokens(), orgCurrency(mu.Org)) }</p>
							</div>
							<div>
								<span class="text-muted-foreground">Complétion (1M tokens)</span>
								<p class="font-medium">{ formatCostPerM(mu.Model.CompletionCostPer1KTokens(), orgCurrency(mu.Org)) }</p>
							</div>
						</div>
						if mu.Aggregate != nil && mu.Aggregate.TotalRequests > 0 {
							<div class="border-t pt-3 grid grid-cols-3 gap-2 text-sm">
								<div>
									<span class="text-muted-foreground">Requêtes</span>
									<p class="font-medium">{ fmt.Sprintf("%d", mu.Aggregate.TotalRequests) }</p>
								</div>
								<div>
									<span class="text-muted-foreground">Tokens</span>
									<p class="font-medium">{ fmt.Sprintf("%d", mu.Aggregate.TotalTokens) }</p>
								</div>
								<div>
									<span class="text-muted-foreground">Coût</span>
									<p class="font-medium">{ formatCost(mu.Aggregate.TotalCost, mu.Aggregate.Currency) }</p>
								</div>
							</div>
						}
					</div>
				}
			}
		}
	</div>
}
