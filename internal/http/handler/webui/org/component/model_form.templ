package component

import (
	"fmt"
	"strconv"

	"github.com/bornholm/xolo/internal/core/rbac"
	common "github.com/bornholm/xolo/internal/http/handler/webui/common/component"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/alert"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/button"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/form"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/input"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/selectbox"
	switchcomp "github.com/bornholm/xolo/internal/http/handler/webui/templui/component/switch"
)

// ── Model Form ────────────────────────────────────────────────────────────────
templ ModelForm(vmodel ModelFormVModel) {
	{{ readonly := !common.HasPermission(ctx, vmodel.Org.ID(), rbac.PermProvidersWrite) }}
	{{ title := "Nouveau modèle" }}
	{{ action := common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(vmodel.Provider.ID()), "/models")) }}
	if !vmodel.IsNew && vmodel.Model != nil {
		{{ title = "Modifier — " + vmodel.Model.ProxyName() }}
		{{ action = common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(vmodel.Provider.ID()), "/models/", string(vmodel.Model.ID()), "/edit")) }}
	}
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle(title), common.WithScripts(common.Script{Name: "selectbox", Component: selectbox.Script()})) {
		<script>
		async function fillFromModelsDev(btn) {
			var form = btn.closest('form');
			var id = form.querySelector('[name=real_model]').value.trim();
			if (!id) { alert('Renseignez d\'abord le nom du modèle réel.'); return; }
			btn.disabled = true;
			try {
				var url = btn.dataset.lookupUrl + '?id=' + encodeURIComponent(id);
			if (btn.dataset.providerType) url += '&provider=' + encodeURIComponent(btn.dataset.providerType);
			var r = await fetch(url);
				if (!r.ok) { alert('Modèle non trouvé dans le catalogue models.dev.'); return; }
				var d = await r.json();
				var f = function(n, v) { var el = form.querySelector('[name=' + n + ']'); if (el) el.value = v; };
				var c = function(n, v) { var el = form.querySelector('[name=' + n + ']'); if (el) el.checked = v; };
				if (d.context_window) f('context_window', d.context_window);
				if (d.output_window) f('output_window', d.output_window);
				if (d.prompt_cost || d.completion_cost) {
					var currency = btn.dataset.currency || 'USD';
					var rate = 1;
					if (currency !== 'USD') {
						var rr = await fetch(btn.dataset.exchangeRateUrl + '?from=USD&to=' + encodeURIComponent(currency));
						if (rr.ok) { var rd = await rr.json(); rate = rd.rate; }
					}
					if (d.prompt_cost) f('prompt_cost', (d.prompt_cost / 1000 * rate).toFixed(6));
					if (d.completion_cost) f('completion_cost', (d.completion_cost / 1000 * rate).toFixed(6));
				}
				c('cap_tools', !!d.cap_tools);
				c('cap_vision', !!d.cap_vision);
				c('cap_reasoning', !!d.cap_reasoning);
				c('cap_audio', !!d.cap_audio);
				c('cap_embeddings', !!d.cap_embeddings);
				if (d.name) { var pn = form.querySelector('[name=proxy_name]'); if (pn && !pn.value) pn.value = d.name; }
			} finally {
				btn.disabled = false;
			}
		}
		</script>
		<div class="space-y-6">
			<h1 class="text-2xl font-semibold">{ title }</h1>
			if vmodel.Error != "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDestructive}) {
					{ vmodel.Error }
				}
			}
			<form method="POST" action={ templ.SafeURL(action) } class="space-y-4">
				<div class="bg-card shadow-xs w-full border text-card-foreground rounded-lg">
					<div class="p-6">
						<div class="space-y-6 pt-4">
							<!-- ── Section 1: Identité ───────────────────────────── -->
							<div class="space-y-4">
								<h3 class="text-sm font-semibold uppercase text-muted-foreground">Identité</h3>
								<div class="space-y-2">
									@form.Label(form.LabelProps{}) { Nom proxy (ce que le client envoie) }
									@form.Description() { Le client devra utiliser le format <code>{ vmodel.Org.Slug() + "/" + "&lt;nom&gt;" }</code>. }
									if !vmodel.IsNew && vmodel.Model != nil {
										@input.Input(input.Props{Name: "proxy_name", Value: vmodel.Model.ProxyName(), Disabled: readonly})
									} else {
										@input.Input(input.Props{Name: "proxy_name", Placeholder: "gpt-4o", Disabled: readonly})
									}
								</div>
								<div class="space-y-2">
									<div class="flex items-center justify-between">
										@form.Label(form.LabelProps{}) { Modèle réel (transmis au fournisseur) }
										@button.Button(button.Props{
											Variant: button.VariantLink,
											Class:   "text-xs h-auto p-0",
											Attributes: templ.Attributes{
												"type":                   "button",
												"data-lookup-url":        common.BaseURLString(ctx, common.WithPath("/api/models-dev/lookup")),
												"data-exchange-rate-url": common.BaseURLString(ctx, common.WithPath("/api/exchange-rate")),
												"data-currency":          vmodel.Provider.Currency(),
												"data-provider-type":     vmodel.Provider.Type(),
												"onclick":                "fillFromModelsDev(this)",
											},
										}) {
											Pré-remplir depuis models.dev
										}
									</div>
									if !vmodel.IsNew && vmodel.Model != nil {
										@input.Input(input.Props{Name: "real_model", Value: vmodel.Model.RealModel(), Disabled: readonly})
									} else {
										@input.Input(input.Props{Name: "real_model", Placeholder: "gpt-4o-2024-11-20", Disabled: readonly})
									}
								</div>
								<div class="space-y-2">
									@form.Label(form.LabelProps{}) { Description }
									if !vmodel.IsNew && vmodel.Model != nil {
										@input.Input(input.Props{Name: "description", Value: vmodel.Model.Description(), Disabled: readonly})
									} else {
										@input.Input(input.Props{Name: "description", Disabled: readonly})
									}
								</div>
							</div>
							<!-- ── Section 2: Contexte & Sortie ──────────────────── -->
							<div class="space-y-4">
								<h3 class="text-sm font-semibold uppercase text-muted-foreground">Contexte & Sortie</h3>
								<div class="grid grid-cols-2 gap-3">
									<div class="space-y-2">
										@form.Label(form.LabelProps{}) { Fenêtre de contexte (tokens) }
										if !vmodel.IsNew && vmodel.Model != nil {
											@input.Input(input.Props{Name: "context_window", Type: "number", Value: fmtInt(vmodel.Model.ContextWindow()), Placeholder: "128000", Disabled: readonly})
										} else {
											@input.Input(input.Props{Name: "context_window", Type: "number", Placeholder: "128000", Disabled: readonly})
										}
									</div>
									<div class="space-y-2">
										@form.Label(form.LabelProps{}) { Fenêtre de sortie (tokens) }
										if !vmodel.IsNew && vmodel.Model != nil {
											@input.Input(input.Props{Name: "output_window", Type: "number", Value: fmtInt(vmodel.Model.OutputWindow()), Placeholder: "8192", Disabled: readonly})
										} else {
											@input.Input(input.Props{Name: "output_window", Type: "number", Placeholder: "8192", Disabled: readonly})
										}
									</div>
								</div>
							</div>
							<!-- ── Section 3: Capacités ─────────────────────────── -->
							<div class="space-y-4">
								<h3 class="text-sm font-semibold uppercase text-muted-foreground">Capacités</h3>
								<div class="rounded-md border p-4 space-y-3">
									{{ capTools := !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.Capabilities().Tools }}
									{{ capVision := !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.Capabilities().Vision }}
									{{ capReasoning := !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.Capabilities().Reasoning }}
									{{ capAudio := !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.Capabilities().Audio }}
									{{ capEmbeddings := !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.Capabilities().Embeddings }}
									@form.ItemFlex() {
										@switchcomp.Switch(switchcomp.Props{ID: "cap_tools", Name: "cap_tools", Checked: capTools, Disabled: readonly})
										@form.Label(form.LabelProps{For: "cap_tools"}) {
											Outils (tools)
										}
									}
									@form.ItemFlex() {
										@switchcomp.Switch(switchcomp.Props{ID: "cap_vision", Name: "cap_vision", Checked: capVision, Disabled: readonly})
										@form.Label(form.LabelProps{For: "cap_vision"}) {
											Vision
										}
									}
									@form.ItemFlex() {
										@switchcomp.Switch(switchcomp.Props{ID: "cap_reasoning", Name: "cap_reasoning", Checked: capReasoning, Disabled: readonly})
										@form.Label(form.LabelProps{For: "cap_reasoning"}) {
											Raisonnement (reasoning)
										}
									}
									@form.ItemFlex() {
										@switchcomp.Switch(switchcomp.Props{ID: "cap_audio", Name: "cap_audio", Checked: capAudio, Disabled: readonly})
										@form.Label(form.LabelProps{For: "cap_audio"}) {
											Audio
										}
									}
									@form.ItemFlex() {
										@switchcomp.Switch(switchcomp.Props{ID: "cap_embeddings", Name: "cap_embeddings", Checked: capEmbeddings, Disabled: readonly})
										@form.Label(form.LabelProps{For: "cap_embeddings"}) {
											Embeddings
										}
									}
								</div>
							</div>
							<!-- ── Section 4: Performance ────────────────────────── -->
							<div class="space-y-4">
								<h3 class="text-sm font-semibold uppercase text-muted-foreground">Performance</h3>
								<div class="space-y-2">
									@form.Label(form.LabelProps{}) { Paramètres actifs (milliards) }
									@form.Description() { Nombre de paramètres actifs par token (ex : 7 pour un modèle 7B). Laisser à 0 si inconnu. }
									if !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.ActiveParams() > 0 {
										@input.Input(input.Props{Name: "active_params", Type: "number", Value: formatActiveParamsBillions(vmodel.Model.ActiveParams()), Placeholder: "7", Disabled: readonly, Attributes: templ.Attributes{"step": "any", "min": "0"}})
									} else {
										@input.Input(input.Props{Name: "active_params", Type: "number", Placeholder: "7", Disabled: readonly, Attributes: templ.Attributes{"step": "any", "min": "0"}})
									}
								</div>
								<div class="grid grid-cols-2 gap-3">
									<div class="space-y-2">
										@form.Label(form.LabelProps{}) { Débit min (tokens/s) }
										if !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.TokensPerSecLow() > 0 {
											@input.Input(input.Props{Name: "tokens_per_sec_low", Type: "number", Value: strconv.FormatFloat(vmodel.Model.TokensPerSecLow(), 'f', -1, 64), Placeholder: "30", Disabled: readonly, Attributes: templ.Attributes{"step": "any", "min": "0"}})
										} else {
											@input.Input(input.Props{Name: "tokens_per_sec_low", Type: "number", Placeholder: "30", Disabled: readonly, Attributes: templ.Attributes{"step": "any", "min": "0"}})
										}
									</div>
									<div class="space-y-2">
										@form.Label(form.LabelProps{}) { Débit max (tokens/s) }
										if !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.TokensPerSecHigh() > 0 {
											@input.Input(input.Props{Name: "tokens_per_sec_high", Type: "number", Value: strconv.FormatFloat(vmodel.Model.TokensPerSecHigh(), 'f', -1, 64), Placeholder: "100", Disabled: readonly, Attributes: templ.Attributes{"step": "any", "min": "0"}})
										} else {
											@input.Input(input.Props{Name: "tokens_per_sec_high", Type: "number", Placeholder: "100", Disabled: readonly, Attributes: templ.Attributes{"step": "any", "min": "0"}})
										}
									</div>
								</div>
								@form.Description() { Débit estimé en tokens/s (min et max). Laisser à 0 pour auto-estimation selon la taille du modèle. }
							</div>
							<!-- ── Section 5: Tarification ────────────────────────── -->
							<div class="space-y-4">
								<h3 class="text-sm font-semibold uppercase text-muted-foreground">Tarification</h3>
								<div class="grid grid-cols-3 gap-3">
									<div class="space-y-2">
										@form.Label(form.LabelProps{}) { Coût prompt par million de tokens ({ vmodel.Provider.Currency() }) }
										if !vmodel.IsNew && vmodel.Model != nil {
											@input.Input(input.Props{Name: "prompt_cost", Type: "number", Value: formatCostField(vmodel.Model.PromptCostPer1KTokens()), Placeholder: "2.50", Disabled: readonly, Attributes: templ.Attributes{"step": "any"}})
										} else {
											@input.Input(input.Props{Name: "prompt_cost", Type: "number", Placeholder: "2.50", Disabled: readonly, Attributes: templ.Attributes{"step": "any"}})
										}
									</div>
									<div class="space-y-2">
										@form.Label(form.LabelProps{}) { Coût prompt en cache par million de tokens ({ vmodel.Provider.Currency() }) }
										@form.Description() { Tarif appliqué aux tokens servis depuis le cache du fournisseur (prompt caching). }
										if !vmodel.IsNew && vmodel.Model != nil {
											@input.Input(input.Props{Name: "cached_prompt_cost", Type: "number", Value: formatCostField(vmodel.Model.CachedPromptCostPer1KTokens()), Placeholder: "0.25", Disabled: readonly, Attributes: templ.Attributes{"step": "any"}})
										} else {
											@input.Input(input.Props{Name: "cached_prompt_cost", Type: "number", Placeholder: "0.25", Disabled: readonly, Attributes: templ.Attributes{"step": "any"}})
										}
									</div>
									<div class="space-y-2">
										@form.Label(form.LabelProps{}) { Coût complétion par million de tokens ({ vmodel.Provider.Currency() }) }
										if !vmodel.IsNew && vmodel.Model != nil {
											@input.Input(input.Props{Name: "completion_cost", Type: "number", Value: formatCostField(vmodel.Model.CompletionCostPer1KTokens()), Placeholder: "10.00", Disabled: readonly, Attributes: templ.Attributes{"step": "any"}})
										} else {
											@input.Input(input.Props{Name: "completion_cost", Type: "number", Placeholder: "10.00", Disabled: readonly, Attributes: templ.Attributes{"step": "any"}})
										}
									</div>
								</div>
							</div>
						</div>
					</div>
					if !vmodel.IsNew && vmodel.Model != nil {
						<div class="p-6 pt-0">
							<div class="space-y-4 pt-4">
								<!-- ── Section 6: Options avancées ──────────────────── -->
								<h3 class="text-sm font-semibold uppercase text-muted-foreground">Options avancées</h3>
								<div class="rounded-md border p-4 space-y-3">
									@form.ItemFlex() {
										@switchcomp.Switch(switchcomp.Props{ID: "enabled", Name: "enabled", Checked: vmodel.Model.Enabled(), Disabled: readonly})
										@form.Label(form.LabelProps{For: "enabled"}) {
											Activé
										}
									}
									// ── Token limit ──────────────────────────────────────────
									{{ tlCfg := vmodel.Model.TokenLimitConfig() }}
									<div class="space-y-3">
										{{ tlEnabled := tlCfg != nil && tlCfg.Enabled }}
										@form.ItemFlex() {
											@switchcomp.Switch(switchcomp.Props{ID: "token_limit_enabled", Name: "token_limit_enabled", Checked: tlEnabled, Disabled: readonly})
											@form.Label(form.LabelProps{For: "token_limit_enabled"}) {
												Limite de tokens (chat completion)
											}
										}
										<div class="grid grid-cols-2 gap-3">
											<div class="space-y-2">
												@form.Label(form.LabelProps{}) { Tokens max par intervalle }
												if tlCfg != nil {
													@input.Input(input.Props{Name: "token_limit_max_tokens", Type: "number", Value: fmt.Sprintf("%d", tlCfg.MaxTokens), Placeholder: "100000", Disabled: readonly, Attributes: templ.Attributes{"min": "1"}})
												} else {
													@input.Input(input.Props{Name: "token_limit_max_tokens", Type: "number", Placeholder: "100000", Disabled: readonly, Attributes: templ.Attributes{"min": "1"}})
												}
											</div>
											<div class="space-y-2">
												@form.Label(form.LabelProps{}) { Durée de l'intervalle }
												<div class="flex gap-2">
													if tlCfg != nil {
														@input.Input(input.Props{Name: "token_limit_interval_value", Type: "number", Value: durationValue(tlCfg.Interval), Placeholder: "1", Disabled: readonly, Attributes: templ.Attributes{"min": "1", "class": "flex-1"}})
													} else {
														@input.Input(input.Props{Name: "token_limit_interval_value", Type: "number", Placeholder: "1", Disabled: readonly, Attributes: templ.Attributes{"min": "1", "class": "flex-1"}})
													}
													@selectbox.SelectBox(selectbox.Props{ID: "token_limit_interval_unit", Class: "w-24"}) {
														@selectbox.Trigger(selectbox.TriggerProps{Name: "token_limit_interval_unit", Disabled: readonly}) {
															@selectbox.Value(selectbox.ValueProps{Placeholder: "Unité"})
														}
														@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
															@selectbox.Group() {
																@selectbox.Item(selectbox.ItemProps{Value: "ms", Selected: tlCfg != nil && durationUnit(tlCfg.Interval) == "ms"}) {
																	ms
																}
																@selectbox.Item(selectbox.ItemProps{Value: "s", Selected: tlCfg == nil || durationUnit(tlCfg.Interval) == "s"}) {
																	s
																}
																@selectbox.Item(selectbox.ItemProps{Value: "min", Selected: tlCfg != nil && durationUnit(tlCfg.Interval) == "min"}) {
																	min
																}
															}
														}
													}
												</div>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
					}
					if common.HasPermission(ctx, vmodel.Org.ID(), rbac.PermProvidersWrite) {
						<div class="pt-0 flex items-center p-6">
							@button.Button(button.Props{Type: button.TypeSubmit}) {
								Enregistrer
							}
						</div>
					}
				</div>
			</form>
			if !vmodel.IsNew && vmodel.Model != nil {
				@button.Button(button.Props{
					Variant: button.VariantDestructive,
					Type:    button.TypeButton,
					Attributes: templ.Attributes{
						"data-url": common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(vmodel.Provider.ID()), "/models/", string(vmodel.Model.ID()))),
						"onclick":  "if(confirm('Supprimer ce modèle ?'))fetch(this.dataset.url,{method:'DELETE'}).then(r=>window.location.href=r.url)",
					},
				}) {
					Supprimer le modèle
				}
			}
		</div>
	}
}
