package component

import (
	"fmt"
	"github.com/bornholm/xolo/internal/core/model"
	common "github.com/bornholm/xolo/internal/http/handler/webui/common/component"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/alert"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/badge"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/button"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/card"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/chart"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/checkbox"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/icon"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/input"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/pagination"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/popover"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/selectbox"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/separator"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/table"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/tooltip"
	"slices"
	"strconv"
	"strings"
	"time"
)

// ── Org Dashboard ─────────────────────────────────────────────────────────────
templ OrgDashboard(vmodel OrgDashboardVModel) {
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle(vmodel.Org.Name())) {
		<div class="space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="text-2xl font-semibold">{ vmodel.Org.Name() }</h1>
					<p class="text-sm text-muted-foreground">{ vmodel.Org.Description() }</p>
				</div>
			</div>
			@separator.Separator()
			<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
				@card.Card() {
					@card.Header() {
						@card.Title() {
							Membres
						}
					}
					@card.Content() {
						<p class="text-3xl font-bold">{ fmt.Sprintf("%d", len(vmodel.Members)) }</p>
					}
					@card.Footer() {
						@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/members")), Variant: button.VariantOutline, Size: button.SizeSm}) {
							Gérer
						}
					}
				}
				@card.Card() {
					@card.Header() {
						@card.Title() {
							Fournisseurs
						}
					}
					@card.Content() {
						<p class="text-3xl font-bold">{ fmt.Sprintf("%d", len(vmodel.Providers)) }</p>
					}
					@card.Footer() {
						@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers")), Variant: button.VariantOutline, Size: button.SizeSm}) {
							Gérer
						}
					}
				}
				@card.Card() {
					@card.Header() {
						@card.Title() {
							Usage (30j)
						}
					}
					@card.Content() {
						<p class="text-3xl font-bold">—</p>
					}
					@card.Footer() {
						@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/usage")), Variant: button.VariantOutline, Size: button.SizeSm}) {
							Voir
						}
					}
				}
			</div>
		</div>
	}
}

// ── Members Page ──────────────────────────────────────────────────────────────
templ MembersPage(vmodel MembersPageVModel) {
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle("Membres — "+vmodel.Org.Name())) {
		<div class="space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="text-2xl font-semibold">Membres</h1>
					<p class="text-sm text-muted-foreground">{ vmodel.Org.Name() }</p>
				</div>
				@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/invites/new"))}) {
					@icon.UserPlus(icon.Props{Class: "h-4 w-4 mr-2"})
					Inviter
				}
			</div>
			if vmodel.Success != "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
					@alert.Description() {
						Opération réussie.
					}
				}
			}
			if len(vmodel.Members) == 0 {
				<div class="rounded-lg border p-6 text-center text-muted-foreground">
					Aucun membre. Créez un lien d'invitation pour ajouter des utilisateurs.
				</div>
			} else {
				@card.Card() {
					@card.Content() {
						@table.Table() {
							@table.Header() {
								@table.Head() {
									Utilisateur
								}
								@table.Head() {
									Email
								}
								@table.Head() {
									Rôle
								}
								@table.Head() {
									Actions
								}
							}
							@table.Body() {
								for _, m := range vmodel.Members {
									@table.Row() {
										@table.Cell() {
											if m.User() != nil {
												{ m.User().DisplayName() }
											}
										}
										@table.Cell() {
											if m.User() != nil {
												{ m.User().Email() }
											}
										}
										@table.Cell() {
											@badge.Badge(badge.Props{Variant: badge.VariantSecondary}) {
												{ m.Role() }
											}
										}
										@table.Cell() {
											@button.Button(button.Props{
												Variant: button.VariantDestructive,
												Size:    button.SizeSm,
												Attributes: templ.Attributes{
													"type":     "button",
													"data-url": common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/members/", string(m.ID()))),
													"onclick":  "if(confirm('Retirer ce membre ?'))fetch(this.dataset.url,{method:'DELETE'}).then(r=>window.location.href=r.url)",
												},
											}) {
												Retirer
											}
											@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/members/", string(m.ID()), "/edit")), Variant: button.VariantOutline, Size: button.SizeSm}) {
												Modifier
											}
											@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/members/", string(m.ID()), "/quota")), Variant: button.VariantOutline, Size: button.SizeSm}) {
												Quota
											}
										}
									}
								}
							}
						}
					}
				}
			}
			@membersPagination(vmodel)
		</div>
	}
}

templ membersPagination(vmodel MembersPageVModel) {
	{{ totalPages := (vmodel.TotalMembers + vmodel.PageSize - 1) / vmodel.PageSize }}
	if totalPages > 1 {
		{{ paginator := pagination.CreatePagination(vmodel.CurrentPage, totalPages, 5) }}
		@pagination.Pagination() {
			@pagination.Content() {
				@pagination.Previous(pagination.PreviousProps{
					Href:     common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/members"), common.WithValues("page", strconv.Itoa(vmodel.CurrentPage-1))),
					Disabled: !paginator.HasPrevious,
					Label:    "Précédent",
				})
				for _, page := range paginator.Pages {
					@pagination.Item() {
						@pagination.Link(pagination.LinkProps{
							Href:     common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/members"), common.WithValues("page", strconv.Itoa(page))),
							IsActive: page == vmodel.CurrentPage,
						}) {
							{ strconv.Itoa(page) }
						}
					}
				}
				@pagination.Next(pagination.NextProps{
					Href:     common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/members"), common.WithValues("page", strconv.Itoa(vmodel.CurrentPage+1))),
					Disabled: !paginator.HasNext,
					Label:    "Suivant",
				})
			}
		}
	}
}

// ── Providers Page ────────────────────────────────────────────────────────────
templ ProvidersPage(vmodel ProvidersPageVModel) {
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle("Fournisseurs — "+vmodel.Org.Name())) {
		<div class="space-y-6">
			<div class="flex items-center justify-between">
				<h1 class="text-2xl font-semibold">Fournisseurs LLM</h1>
				@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/new"))}) {
					@icon.Plus(icon.Props{Class: "h-4 w-4 mr-2"})
					Ajouter
				}
			</div>
			if vmodel.Success != "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
					@alert.Description() {
						Opération réussie.
					}
				}
			}
			if len(vmodel.Providers) == 0 {
				<div class="rounded-lg border p-6 text-center text-muted-foreground">
					Aucun fournisseur. Ajoutez un fournisseur LLM pour commencer.
				</div>
			} else {
				@card.Card() {
					@card.Content() {
						@table.Table() {
							@table.Header() {
								@table.Head() {
									Nom
								}
								@table.Head() {
									Type
								}
								@table.Head() {
									Statut
								}
								@table.Head() {
									Actions
								}
							}
							@table.Body() {
								for _, p := range vmodel.Providers {
									@table.Row() {
										@table.Cell() {
											{ p.Name() }
										}
										@table.Cell() {
											@badge.Badge(badge.Props{Variant: badge.VariantSecondary}) {
												{ p.Type() }
											}
										}
										@table.Cell() {
											if p.Active() {
												@badge.Badge(badge.Props{Variant: badge.VariantDefault}) {
													Actif
												}
											} else {
												@badge.Badge(badge.Props{Variant: badge.VariantDestructive}) {
													Inactif
												}
											}
										}
										@table.Cell() {
											<div class="flex gap-2">
												@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(p.ID()), "/models")), Variant: button.VariantOutline, Size: button.SizeSm}) {
													Modèles
												}
												@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(p.ID()), "/edit")), Variant: button.VariantOutline, Size: button.SizeSm}) {
													Modifier
												}
											</div>
										}
									}
								}
							}
						}
					}
				}
			}
		</div>
	}
}

// ── Provider Form ─────────────────────────────────────────────────────────────
templ ProviderForm(vmodel ProviderFormVModel) {
	{{ title := "Nouveau fournisseur" }}
	{{ action := common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers")) }}
	if !vmodel.IsNew && vmodel.Provider != nil {
		{{ title = "Modifier — " + vmodel.Provider.Name() }}
		{{ action = common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(vmodel.Provider.ID()), "/edit")) }}
	}
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle(title)) {
		<div class="space-y-6">
			<h1 class="text-2xl font-semibold">{ title }</h1>
			if vmodel.Error != "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDestructive}) {
					@alert.Description() {
						{ vmodel.Error }
					}
				}
			}
			<form method="POST" action={ templ.SafeURL(action) } class="space-y-4">
				<div class="space-y-2">
					<label class="text-sm font-medium">Nom</label>
					if !vmodel.IsNew && vmodel.Provider != nil {
						@input.Input(input.Props{Name: "name", Value: vmodel.Provider.Name()})
					} else {
						@input.Input(input.Props{Name: "name"})
					}
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">Type</label>
					@selectbox.SelectBox(selectbox.Props{ID: "provider_type"}) {
						@selectbox.Trigger(selectbox.TriggerProps{Name: "provider_type"}) {
							@selectbox.Value(selectbox.ValueProps{Placeholder: "Sélectionner un type"})
						}
						@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
							@selectbox.Group() {
								for _, t := range []string{"openai", "mistral", "openrouter", "yzma"} {
									@selectbox.Item(selectbox.ItemProps{Value: t, Selected: !vmodel.IsNew && vmodel.Provider != nil && vmodel.Provider.Type() == t}) {
										{ t }
									}
								}
							}
						}
					}
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">URL de base</label>
					<p class="text-xs text-muted-foreground">
						Exemples : <code>https://api.openai.com/v1</code>, <code>https://api.mistral.ai/v1</code>, <code>https://openrouter.ai/api/v1</code>
					</p>
					if !vmodel.IsNew && vmodel.Provider != nil {
						@input.Input(input.Props{Name: "base_url", Value: vmodel.Provider.BaseURL(), Placeholder: "https://api.mistral.ai/v1", Attributes: templ.Attributes{"required": "required"}})
					} else {
						@input.Input(input.Props{Name: "base_url", Placeholder: "https://api.mistral.ai/v1", Attributes: templ.Attributes{"required": "required"}})
					}
				</div>
				<div class="space-y-2">
					if vmodel.IsNew {
						<label class="text-sm font-medium">Clé API</label>
					} else {
						<label class="text-sm font-medium">Clé API (laisser vide pour conserver)</label>
					}
					@input.Input(input.Props{Name: "api_key", Type: "password", Placeholder: "sk-..."})
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">Devise</label>
					@selectbox.SelectBox(selectbox.Props{ID: "provider_currency"}) {
						@selectbox.Trigger(selectbox.TriggerProps{Name: "currency"}) {
							@selectbox.Value(selectbox.ValueProps{Placeholder: "Sélectionner une devise"})
						}
						@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
							@selectbox.Group() {
								for _, c := range model.SupportedCurrencies {
									@selectbox.Item(selectbox.ItemProps{Value: c, Selected: !vmodel.IsNew && vmodel.Provider != nil && vmodel.Provider.Currency() == c}) {
										{ c }
									}
								}
							}
						}
					}
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">Niveau d'infrastructure (CloudTier)</label>
					<p class="text-xs text-muted-foreground">Utilisé pour l'estimation de consommation énergétique.</p>
					{{ currentTier := 0 }}
					if !vmodel.IsNew && vmodel.Provider != nil {
						{{ currentTier = vmodel.Provider.CloudTier() }}
					}
					@selectbox.SelectBox(selectbox.Props{ID: "cloud_tier"}) {
						@selectbox.Trigger(selectbox.TriggerProps{Name: "cloud_tier"}) {
							@selectbox.Value(selectbox.ValueProps{Placeholder: "Sélectionner un niveau"})
						}
						@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
							@selectbox.Group() {
								@selectbox.Item(selectbox.ItemProps{Value: "0", Selected: currentTier == 0}) {
									Hyperscaler (Google, Microsoft, OpenAI, Anthropic)
								}
								@selectbox.Item(selectbox.ItemProps{Value: "1", Selected: currentTier == 1}) {
									Major Cloud (AWS, OVH, CoreWeave, Mistral)
								}
								@selectbox.Item(selectbox.ItemProps{Value: "2", Selected: currentTier == 2}) {
									Small Provider
								}
							}
						}
					}
				</div>
				if !vmodel.IsNew && vmodel.Provider != nil {
					<div class="flex items-center gap-2">
						@checkbox.Checkbox(checkbox.Props{ID: "active", Name: "active", Checked: vmodel.Provider.Active()})
						<label for="active" class="text-sm font-medium">Actif</label>
					</div>
					@button.Button(button.Props{
						Href:    common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(vmodel.Provider.ID()), "/test")),
						Variant: button.VariantOutline,
						Type:    "button",
					}) {
						Tester la connexion
					}
					// ── Retry ────────────────────────────────────────────────
					{{ retryCfg := vmodel.Provider.RetryConfig() }}
					<div class="rounded-md border p-4 space-y-3">
						{{ retryEnabled := retryCfg != nil && retryCfg.Enabled }}
						<div class="flex items-center gap-2">
							@checkbox.Checkbox(checkbox.Props{ID: "retry_enabled", Name: "retry_enabled", Checked: retryEnabled})
							<label for="retry_enabled" class="text-sm font-semibold">Retry (nouvelle tentative)</label>
						</div>
						<div class="grid grid-cols-2 gap-3">
							<div class="space-y-2">
								<label class="text-sm font-medium">Nombre de tentatives</label>
								if retryCfg != nil {
									@input.Input(input.Props{Name: "retry_max_attempts", Type: "number", Value: fmt.Sprintf("%d", retryCfg.MaxAttempts), Placeholder: "3", Attributes: templ.Attributes{"min": "1"}})
								} else {
									@input.Input(input.Props{Name: "retry_max_attempts", Type: "number", Placeholder: "3", Attributes: templ.Attributes{"min": "1"}})
								}
							</div>
							<div class="space-y-2">
								<label class="text-sm font-medium">Délai entre tentatives</label>
								<div class="flex gap-2">
									if retryCfg != nil {
										@input.Input(input.Props{Name: "retry_delay_value", Type: "number", Value: durationValue(retryCfg.Delay), Placeholder: "1", Attributes: templ.Attributes{"min": "1", "class": "flex-1"}})
									} else {
										@input.Input(input.Props{Name: "retry_delay_value", Type: "number", Placeholder: "1", Attributes: templ.Attributes{"min": "1", "class": "flex-1"}})
									}
									@selectbox.SelectBox(selectbox.Props{ID: "retry_delay_unit", Class: "w-24"}) {
										@selectbox.Trigger(selectbox.TriggerProps{Name: "retry_delay_unit"}) {
											@selectbox.Value(selectbox.ValueProps{Placeholder: "Unité"})
										}
										@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
											@selectbox.Group() {
												@selectbox.Item(selectbox.ItemProps{Value: "ms", Selected: retryCfg != nil && durationUnit(retryCfg.Delay) == "ms"}) {
													ms
												}
												@selectbox.Item(selectbox.ItemProps{Value: "s", Selected: retryCfg == nil || durationUnit(retryCfg.Delay) == "s"}) {
													s
												}
												@selectbox.Item(selectbox.ItemProps{Value: "min", Selected: retryCfg != nil && durationUnit(retryCfg.Delay) == "min"}) {
													min
												}
											}
										}
									}
								</div>
							</div>
						</div>
					</div>
					// ── Rate limit ───────────────────────────────────────────
					{{ rlCfg := vmodel.Provider.RateLimitConfig() }}
					<div class="rounded-md border p-4 space-y-3">
						{{ rlEnabled := rlCfg != nil && rlCfg.Enabled }}
						<div class="flex items-center gap-2">
							@checkbox.Checkbox(checkbox.Props{ID: "rate_limit_enabled", Name: "rate_limit_enabled", Checked: rlEnabled})
							<label for="rate_limit_enabled" class="text-sm font-semibold">Rate limit (limitation de débit)</label>
						</div>
						<div class="grid grid-cols-2 gap-3">
							<div class="space-y-2">
								<label class="text-sm font-medium">Intervalle minimum entre requêtes</label>
								<div class="flex gap-2">
									if rlCfg != nil {
										@input.Input(input.Props{Name: "rate_limit_interval_value", Type: "number", Value: durationValue(rlCfg.Interval), Placeholder: "1", Attributes: templ.Attributes{"min": "1", "class": "flex-1"}})
									} else {
										@input.Input(input.Props{Name: "rate_limit_interval_value", Type: "number", Placeholder: "1", Attributes: templ.Attributes{"min": "1", "class": "flex-1"}})
									}
									@selectbox.SelectBox(selectbox.Props{ID: "rate_limit_interval_unit", Class: "w-24"}) {
										@selectbox.Trigger(selectbox.TriggerProps{Name: "rate_limit_interval_unit"}) {
											@selectbox.Value(selectbox.ValueProps{Placeholder: "Unité"})
										}
										@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
											@selectbox.Group() {
												@selectbox.Item(selectbox.ItemProps{Value: "ms", Selected: rlCfg != nil && durationUnit(rlCfg.Interval) == "ms"}) {
													ms
												}
												@selectbox.Item(selectbox.ItemProps{Value: "s", Selected: rlCfg == nil || durationUnit(rlCfg.Interval) == "s"}) {
													s
												}
												@selectbox.Item(selectbox.ItemProps{Value: "min", Selected: rlCfg != nil && durationUnit(rlCfg.Interval) == "min"}) {
													min
												}
											}
										}
									}
								</div>
							</div>
							<div class="space-y-2">
								<label class="text-sm font-medium">Capacité de burst (rafale max)</label>
								if rlCfg != nil {
									@input.Input(input.Props{Name: "rate_limit_max_burst", Type: "number", Value: fmt.Sprintf("%d", rlCfg.MaxBurst), Placeholder: "10", Attributes: templ.Attributes{"min": "1"}})
								} else {
									@input.Input(input.Props{Name: "rate_limit_max_burst", Type: "number", Placeholder: "10", Attributes: templ.Attributes{"min": "1"}})
								}
							</div>
						</div>
					</div>
				}
				@button.Button(button.Props{Type: "submit"}) {
					Enregistrer
				}
			</form>
			if !vmodel.IsNew && vmodel.Provider != nil {
				@button.Button(button.Props{
					Variant: button.VariantDestructive,
					Attributes: templ.Attributes{
						"type":     "button",
						"data-url": common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(vmodel.Provider.ID()))),
						"onclick":  "if(confirm('Supprimer ce fournisseur et tous ses modèles ?'))fetch(this.dataset.url,{method:'DELETE'}).then(r=>window.location.href=r.url)",
					},
				}) {
					Supprimer le fournisseur
				}
			}
		</div>
	}
}

// ── Models Page ───────────────────────────────────────────────────────────────
templ ModelsPage(vmodel ModelsPageVModel) {
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle("Modèles — "+vmodel.Provider.Name())) {
		<div class="space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="text-2xl font-semibold">Modèles d'org.</h1>
					<p class="text-sm text-muted-foreground">Fournisseur : { vmodel.Provider.Name() }</p>
				</div>
				@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(vmodel.Provider.ID()), "/models/new"))}) {
					@icon.Plus(icon.Props{Class: "h-4 w-4 mr-2"})
					Ajouter un modèle
				}
			</div>
			if vmodel.Success != "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
					@alert.Description() {
						Opération réussie.
					}
				}
			}
			if len(vmodel.Models) == 0 {
				<div class="rounded-lg border p-6 text-center text-muted-foreground">Aucun modèle.</div>
			} else {
				@card.Card() {
					@card.Content() {
						@table.Table() {
							@table.Header() {
								@table.Head() {
									Nom proxy
								}
								@table.Head() {
									Modèle réel
								}
								@table.Head() {
									Coût prompt/1M
								}
								@table.Head() {
									Coût prompt cache/1M
								}
								@table.Head() {
									Coût compl./1M
								}
								@table.Head() {
									Statut
								}
								@table.Head() {
									Actions
								}
							}
							@table.Body() {
								for _, m := range vmodel.Models {
									@table.Row() {
										@table.Cell() {
											{ vmodel.Org.Slug() + "/" + m.ProxyName() }
										}
										@table.Cell() {
											{ m.RealModel() }
										}
										@table.Cell() {
											{ formatCostRate(m.PromptCostPer1KTokens(), vmodel.Provider.Currency()) }
										}
										@table.Cell() {
											{ formatCostRate(m.CachedPromptCostPer1KTokens(), vmodel.Provider.Currency()) }
										}
										@table.Cell() {
											{ formatCostRate(m.CompletionCostPer1KTokens(), vmodel.Provider.Currency()) }
										}
										@table.Cell() {
											if m.Enabled() {
												@badge.Badge(badge.Props{Variant: badge.VariantDefault}) {
													Actif
												}
											} else {
												@badge.Badge(badge.Props{Variant: badge.VariantSecondary}) {
													Inactif
												}
											}
										}
										@table.Cell() {
											@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(vmodel.Provider.ID()), "/models/", string(m.ID()), "/edit")), Variant: button.VariantOutline, Size: button.SizeSm}) {
												Modifier
											}
										}
									}
								}
							}
						}
					}
				}
			}
		</div>
	}
}

// ── Model Form ────────────────────────────────────────────────────────────────
templ ModelForm(vmodel ModelFormVModel) {
	{{ title := "Nouveau modèle" }}
	{{ action := common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(vmodel.Provider.ID()), "/models")) }}
	if !vmodel.IsNew && vmodel.Model != nil {
		{{ title = "Modifier — " + vmodel.Model.ProxyName() }}
		{{ action = common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(vmodel.Provider.ID()), "/models/", string(vmodel.Model.ID()), "/edit")) }}
	}
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle(title)) {
		<script>
		async function fillFromModelsDev(btn) {
			var form = btn.closest('form');
			var id = form.querySelector('[name=real_model]').value.trim();
			if (!id) { alert('Renseignez d\'abord le nom du modèle réel.'); return; }
			btn.disabled = true;
			try {
				var url = btn.dataset.lookupUrl + '?id=' + encodeURIComponent(id);
			if (btn.dataset.providerType) url += '&provider=' + encodeURIComponent(btn.dataset.providerType);
			var r = await fetch(url);
				if (!r.ok) { alert('Modèle non trouvé dans le catalogue models.dev.'); return; }
				var d = await r.json();
				var f = function(n, v) { var el = form.querySelector('[name=' + n + ']'); if (el) el.value = v; };
				var c = function(n, v) { var el = form.querySelector('[name=' + n + ']'); if (el) el.checked = v; };
				if (d.context_window) f('context_window', d.context_window);
				if (d.output_window) f('output_window', d.output_window);
				if (d.prompt_cost || d.completion_cost) {
					var currency = btn.dataset.currency || 'USD';
					var rate = 1;
					if (currency !== 'USD') {
						var rr = await fetch(btn.dataset.exchangeRateUrl + '?from=USD&to=' + encodeURIComponent(currency));
						if (rr.ok) { var rd = await rr.json(); rate = rd.rate; }
					}
					if (d.prompt_cost) f('prompt_cost', (d.prompt_cost / 1000 * rate).toFixed(6));
					if (d.completion_cost) f('completion_cost', (d.completion_cost / 1000 * rate).toFixed(6));
				}
				c('cap_tools', !!d.cap_tools);
				c('cap_vision', !!d.cap_vision);
				c('cap_reasoning', !!d.cap_reasoning);
				c('cap_audio', !!d.cap_audio);
				c('cap_embeddings', !!d.cap_embeddings);
				if (d.name) { var pn = form.querySelector('[name=proxy_name]'); if (pn && !pn.value) pn.value = d.name; }
			} finally {
				btn.disabled = false;
			}
		}
		</script>
		<div class="space-y-6">
			<h1 class="text-2xl font-semibold">{ title }</h1>
			if vmodel.Error != "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDestructive}) {
					{ vmodel.Error }
				}
			}
			<form method="POST" action={ templ.SafeURL(action) } class="space-y-4">
				<div class="space-y-2">
					<label class="text-sm font-medium">Nom proxy (ce que le client envoie)</label>
					<p class="text-xs text-muted-foreground">Le client devra utiliser le format <code>{ vmodel.Org.Slug() + "/" + "&lt;nom&gt;" }</code>.</p>
					if !vmodel.IsNew && vmodel.Model != nil {
						@input.Input(input.Props{Name: "proxy_name", Value: vmodel.Model.ProxyName()})
					} else {
						@input.Input(input.Props{Name: "proxy_name", Placeholder: "gpt-4o"})
					}
				</div>
				<div class="space-y-2">
					<div class="flex items-center justify-between">
						<label class="text-sm font-medium">Modèle réel (transmis au fournisseur)</label>
						@button.Button(button.Props{
							Variant: button.VariantLink,
							Class:   "text-xs h-auto p-0",
							Attributes: templ.Attributes{
								"type":                   "button",
								"data-lookup-url":        common.BaseURLString(ctx, common.WithPath("/api/models-dev/lookup")),
								"data-exchange-rate-url": common.BaseURLString(ctx, common.WithPath("/api/exchange-rate")),
								"data-currency":          vmodel.Provider.Currency(),
								"data-provider-type":     vmodel.Provider.Type(),
								"onclick":                "fillFromModelsDev(this)",
							},
						}) {
							Pré-remplir depuis models.dev
						}
					</div>
					if !vmodel.IsNew && vmodel.Model != nil {
						@input.Input(input.Props{Name: "real_model", Value: vmodel.Model.RealModel()})
					} else {
						@input.Input(input.Props{Name: "real_model", Placeholder: "gpt-4o-2024-11-20"})
					}
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">Description</label>
					if !vmodel.IsNew && vmodel.Model != nil {
						@input.Input(input.Props{Name: "description", Value: vmodel.Model.Description()})
					} else {
						@input.Input(input.Props{Name: "description"})
					}
				</div>
				<div class="grid grid-cols-2 gap-3">
					<div class="space-y-2">
						<label class="text-sm font-medium">Fenêtre de contexte (tokens)</label>
						if !vmodel.IsNew && vmodel.Model != nil {
							@input.Input(input.Props{Name: "context_window", Type: "number", Value: fmtInt(vmodel.Model.ContextWindow()), Placeholder: "128000"})
						} else {
							@input.Input(input.Props{Name: "context_window", Type: "number", Placeholder: "128000"})
						}
					</div>
					<div class="space-y-2">
						<label class="text-sm font-medium">Fenêtre de sortie (tokens)</label>
						if !vmodel.IsNew && vmodel.Model != nil {
							@input.Input(input.Props{Name: "output_window", Type: "number", Value: fmtInt(vmodel.Model.OutputWindow()), Placeholder: "8192"})
						} else {
							@input.Input(input.Props{Name: "output_window", Type: "number", Placeholder: "8192"})
						}
					</div>
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">Capacités</label>
					<div class="flex flex-wrap gap-4">
						{{ capTools := !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.Capabilities().Tools }}
						{{ capVision := !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.Capabilities().Vision }}
						{{ capReasoning := !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.Capabilities().Reasoning }}
						{{ capAudio := !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.Capabilities().Audio }}
						{{ capEmbeddings := !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.Capabilities().Embeddings }}
						<label class="flex items-center gap-2 text-sm cursor-pointer">
							@checkbox.Checkbox(checkbox.Props{Name: "cap_tools", Checked: capTools})
							Outils (tools)
						</label>
						<label class="flex items-center gap-2 text-sm cursor-pointer">
							@checkbox.Checkbox(checkbox.Props{Name: "cap_vision", Checked: capVision})
							Vision
						</label>
						<label class="flex items-center gap-2 text-sm cursor-pointer">
							@checkbox.Checkbox(checkbox.Props{Name: "cap_reasoning", Checked: capReasoning})
							Raisonnement (reasoning)
						</label>
						<label class="flex items-center gap-2 text-sm cursor-pointer">
							@checkbox.Checkbox(checkbox.Props{Name: "cap_audio", Checked: capAudio})
							Audio
						</label>
						<label class="flex items-center gap-2 text-sm cursor-pointer">
							@checkbox.Checkbox(checkbox.Props{Name: "cap_embeddings", Checked: capEmbeddings})
							Embeddings
						</label>
					</div>
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">Paramètres actifs (milliards)</label>
					<p class="text-xs text-muted-foreground">Nombre de paramètres actifs par token (ex : 7 pour un modèle 7B). Laisser à 0 si inconnu.</p>
					if !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.ActiveParams() > 0 {
						@input.Input(input.Props{Name: "active_params", Type: "number", Value: formatActiveParamsBillions(vmodel.Model.ActiveParams()), Placeholder: "7", Attributes: templ.Attributes{"step": "any", "min": "0"}})
					} else {
						@input.Input(input.Props{Name: "active_params", Type: "number", Placeholder: "7", Attributes: templ.Attributes{"step": "any", "min": "0"}})
					}
				</div>
				<div class="grid grid-cols-2 gap-3">
					<div class="space-y-2">
						<label class="text-sm font-medium">Débit min (tokens/s)</label>
						if !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.TokensPerSecLow() > 0 {
							@input.Input(input.Props{Name: "tokens_per_sec_low", Type: "number", Value: strconv.FormatFloat(vmodel.Model.TokensPerSecLow(), 'f', -1, 64), Placeholder: "30", Attributes: templ.Attributes{"step": "any", "min": "0"}})
						} else {
							@input.Input(input.Props{Name: "tokens_per_sec_low", Type: "number", Placeholder: "30", Attributes: templ.Attributes{"step": "any", "min": "0"}})
						}
					</div>
					<div class="space-y-2">
						<label class="text-sm font-medium">Débit max (tokens/s)</label>
						if !vmodel.IsNew && vmodel.Model != nil && vmodel.Model.TokensPerSecHigh() > 0 {
							@input.Input(input.Props{Name: "tokens_per_sec_high", Type: "number", Value: strconv.FormatFloat(vmodel.Model.TokensPerSecHigh(), 'f', -1, 64), Placeholder: "100", Attributes: templ.Attributes{"step": "any", "min": "0"}})
						} else {
							@input.Input(input.Props{Name: "tokens_per_sec_high", Type: "number", Placeholder: "100", Attributes: templ.Attributes{"step": "any", "min": "0"}})
						}
					</div>
				</div>
				<p class="text-xs text-muted-foreground -mt-2">Débit estimé en tokens/s (min et max). Laisser à 0 pour auto-estimation selon la taille du modèle.</p>
				<div class="grid grid-cols-3 gap-3">
					<div class="space-y-2">
						<label class="text-sm font-medium">Coût prompt par million de tokens ({ vmodel.Provider.Currency() })</label>
						if !vmodel.IsNew && vmodel.Model != nil {
							@input.Input(input.Props{Name: "prompt_cost", Type: "number", Value: formatCostField(vmodel.Model.PromptCostPer1KTokens()), Placeholder: "2.50", Attributes: templ.Attributes{"step": "any"}})
						} else {
							@input.Input(input.Props{Name: "prompt_cost", Type: "number", Placeholder: "2.50", Attributes: templ.Attributes{"step": "any"}})
						}
					</div>
					<div class="space-y-2">
						<label class="text-sm font-medium">Coût prompt en cache par million de tokens ({ vmodel.Provider.Currency() })</label>
						<p class="text-xs text-muted-foreground">Tarif appliqué aux tokens servis depuis le cache du fournisseur (prompt caching). Laisser vide pour utiliser le coût prompt normal.</p>
						if !vmodel.IsNew && vmodel.Model != nil {
							@input.Input(input.Props{Name: "cached_prompt_cost", Type: "number", Value: formatCostField(vmodel.Model.CachedPromptCostPer1KTokens()), Placeholder: "0.25", Attributes: templ.Attributes{"step": "any"}})
						} else {
							@input.Input(input.Props{Name: "cached_prompt_cost", Type: "number", Placeholder: "0.25", Attributes: templ.Attributes{"step": "any"}})
						}
					</div>
					<div class="space-y-2">
						<label class="text-sm font-medium">Coût complétion par million de tokens ({ vmodel.Provider.Currency() })</label>
						if !vmodel.IsNew && vmodel.Model != nil {
							@input.Input(input.Props{Name: "completion_cost", Type: "number", Value: formatCostField(vmodel.Model.CompletionCostPer1KTokens()), Placeholder: "10.00", Attributes: templ.Attributes{"step": "any"}})
						} else {
							@input.Input(input.Props{Name: "completion_cost", Type: "number", Placeholder: "10.00", Attributes: templ.Attributes{"step": "any"}})
						}
					</div>
				</div>
				if !vmodel.IsNew && vmodel.Model != nil {
					<div class="flex items-center gap-2">
						@checkbox.Checkbox(checkbox.Props{ID: "enabled", Name: "enabled", Checked: vmodel.Model.Enabled()})
						<label for="enabled" class="text-sm font-medium">Activé</label>
					</div>
					// ── Token limit ──────────────────────────────────────────
					{{ tlCfg := vmodel.Model.TokenLimitConfig() }}
					<div class="rounded-md border p-4 space-y-3">
						{{ tlEnabled := tlCfg != nil && tlCfg.Enabled }}
						<div class="flex items-center gap-2">
							@checkbox.Checkbox(checkbox.Props{ID: "token_limit_enabled", Name: "token_limit_enabled", Checked: tlEnabled})
							<label for="token_limit_enabled" class="text-sm font-semibold">Limite de tokens (chat completion)</label>
						</div>
						<div class="grid grid-cols-2 gap-3">
							<div class="space-y-2">
								<label class="text-sm font-medium">Tokens max par intervalle</label>
								if tlCfg != nil {
									@input.Input(input.Props{Name: "token_limit_max_tokens", Type: "number", Value: fmt.Sprintf("%d", tlCfg.MaxTokens), Placeholder: "100000", Attributes: templ.Attributes{"min": "1"}})
								} else {
									@input.Input(input.Props{Name: "token_limit_max_tokens", Type: "number", Placeholder: "100000", Attributes: templ.Attributes{"min": "1"}})
								}
							</div>
							<div class="space-y-2">
								<label class="text-sm font-medium">Durée de l'intervalle</label>
								<div class="flex gap-2">
									if tlCfg != nil {
										@input.Input(input.Props{Name: "token_limit_interval_value", Type: "number", Value: durationValue(tlCfg.Interval), Placeholder: "1", Attributes: templ.Attributes{"min": "1", "class": "flex-1"}})
									} else {
										@input.Input(input.Props{Name: "token_limit_interval_value", Type: "number", Placeholder: "1", Attributes: templ.Attributes{"min": "1", "class": "flex-1"}})
									}
									@selectbox.SelectBox(selectbox.Props{ID: "token_limit_interval_unit", Class: "w-24"}) {
										@selectbox.Trigger(selectbox.TriggerProps{Name: "token_limit_interval_unit"}) {
											@selectbox.Value(selectbox.ValueProps{Placeholder: "Unité"})
										}
										@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
											@selectbox.Group() {
												@selectbox.Item(selectbox.ItemProps{Value: "ms", Selected: tlCfg != nil && durationUnit(tlCfg.Interval) == "ms"}) {
													ms
												}
												@selectbox.Item(selectbox.ItemProps{Value: "s", Selected: tlCfg == nil || durationUnit(tlCfg.Interval) == "s"}) {
													s
												}
												@selectbox.Item(selectbox.ItemProps{Value: "min", Selected: tlCfg != nil && durationUnit(tlCfg.Interval) == "min"}) {
													min
												}
											}
										}
									}
								</div>
							</div>
						</div>
					</div>
				}
				@button.Button(button.Props{Type: "submit"}) {
					Enregistrer
				}
			</form>
			if !vmodel.IsNew && vmodel.Model != nil {
				@button.Button(button.Props{
					Variant: button.VariantDestructive,
					Attributes: templ.Attributes{
						"type":     "button",
						"data-url": common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/providers/", string(vmodel.Provider.ID()), "/models/", string(vmodel.Model.ID()))),
						"onclick":  "if(confirm('Supprimer ce modèle ?'))fetch(this.dataset.url,{method:'DELETE'}).then(r=>window.location.href=r.url)",
					},
				}) {
					Supprimer le modèle
				}
			}
		</div>
	}
}

// ── Quota Page ────────────────────────────────────────────────────────────────
templ QuotaPage(vmodel QuotaPageVModel) {
	{{ title := "Budget de l'organisation" }}
	{{ action := common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/quota")) }}
	if vmodel.ScopeType == "user" && vmodel.Membership != nil {
		{{ title = "Budget membre" }}
		{{ action = common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/members/", string(vmodel.Membership.ID()), "/quota")) }}
	}
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle(title)) {
		<div class="space-y-6">
			<h1 class="text-2xl font-semibold">{ title }</h1>
			if vmodel.Success != "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
					@alert.Description() {
						Budget enregistré.
					}
				}
			}
			@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
				@alert.Description() {
					<div>Les budgets sont exprimés dans la devise de l'organisation (<strong>{ vmodel.Org.Currency() }</strong>).</div>
					<div>Pour modifier la devise, rendez-vous dans les <a href={ templ.SafeURL(common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/settings"))) } class="underline font-medium">Paramètres</a>.</div>
				}
			}
			<form method="POST" action={ templ.SafeURL(action) } class="space-y-4">
				<div class="space-y-2">
					<label class="text-sm font-medium">Budget journalier (vide = illimité)</label>
					if vmodel.Quota != nil && vmodel.Quota.DailyBudget() != nil {
						@input.Input(input.Props{Name: "daily_budget", Type: "number", Placeholder: "10.00", Value: formatBudgetField(*vmodel.Quota.DailyBudget()), Attributes: templ.Attributes{"step": "any"}})
					} else {
						@input.Input(input.Props{Name: "daily_budget", Type: "number", Placeholder: "10.00", Attributes: templ.Attributes{"step": "any"}})
					}
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">Budget mensuel (vide = illimité)</label>
					if vmodel.Quota != nil && vmodel.Quota.MonthlyBudget() != nil {
						@input.Input(input.Props{Name: "monthly_budget", Type: "number", Placeholder: "100.00", Value: formatBudgetField(*vmodel.Quota.MonthlyBudget()), Attributes: templ.Attributes{"step": "any"}})
					} else {
						@input.Input(input.Props{Name: "monthly_budget", Type: "number", Placeholder: "100.00", Attributes: templ.Attributes{"step": "any"}})
					}
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">Budget annuel (vide = illimité)</label>
					if vmodel.Quota != nil && vmodel.Quota.YearlyBudget() != nil {
						@input.Input(input.Props{Name: "yearly_budget", Type: "number", Placeholder: "1000.00", Value: formatBudgetField(*vmodel.Quota.YearlyBudget()), Attributes: templ.Attributes{"step": "any"}})
					} else {
						@input.Input(input.Props{Name: "yearly_budget", Type: "number", Placeholder: "1000.00", Attributes: templ.Attributes{"step": "any"}})
					}
				</div>
				@button.Button(button.Props{Type: "submit"}) {
					Enregistrer
				}
			</form>
		</div>
	}
}

// ── Settings Page ─────────────────────────────────────────────────────────────
templ OrgSettingsPage(vmodel OrgSettingsPageVModel) {
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle("Paramètres — "+vmodel.Org.Name())) {
		<div class="space-y-6">
			<h1 class="text-2xl font-semibold">Paramètres</h1>
			if vmodel.Success != "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
					@alert.Description() {
						Paramètres enregistrés.
					}
				}
			}
			<form method="POST" action={ templ.SafeURL(common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/settings"))) } class="space-y-4">
				<div class="space-y-2">
					<label class="text-sm font-medium">Devise préférée</label>
					@selectbox.SelectBox(selectbox.Props{ID: "org_currency"}) {
						@selectbox.Trigger(selectbox.TriggerProps{Name: "currency"}) {
							@selectbox.Value(selectbox.ValueProps{Placeholder: "Sélectionner une devise"})
						}
						@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
							@selectbox.Group() {
								for _, c := range model.SupportedCurrencies {
									@selectbox.Item(selectbox.ItemProps{Value: c, Selected: vmodel.Org.Currency() == c}) {
										{ c }
									}
								}
							}
						}
					}
					<p class="text-xs text-muted-foreground">Utilisée pour les quotas et l'affichage des coûts.</p>
				</div>
				<div class="space-y-2">
					<div class="flex items-center space-x-2">
						@checkbox.Checkbox(checkbox.Props{ID: "share_quota_equally", Name: "share_quota_equally", Checked: vmodel.Org.ShareQuotaEqually()})
						<label for="share_quota_equally" class="text-sm font-medium">
							Répartir le budget de l'organisation équitablement entre les membres
						</label>
					</div>
					<p class="text-xs text-muted-foreground">S'applique aux membres sans quota individuel défini.</p>
					if vmodel.MemberCount > 0 {
						<div class="text-xs text-muted-foreground space-y-1">
							<p>Aperçu ({ strconv.Itoa(vmodel.MemberCount) } membres) :</p>
							if vmodel.SharedDailyBudget != nil {
								<p>Journalier : { common.CurrencySymbol(vmodel.Org.Currency()) }{ formatBudgetField(*vmodel.SharedDailyBudget) }</p>
							}
							if vmodel.SharedMonthlyBudget != nil {
								<p>Mensuel : { common.CurrencySymbol(vmodel.Org.Currency()) }{ formatBudgetField(*vmodel.SharedMonthlyBudget) }</p>
							}
							if vmodel.SharedYearlyBudget != nil {
								<p>Annuel : { common.CurrencySymbol(vmodel.Org.Currency()) }{ formatBudgetField(*vmodel.SharedYearlyBudget) }</p>
							}
						</div>
					}
				</div>
				@button.Button(button.Props{Type: "submit"}) {
					Enregistrer
				}
			</form>
		</div>
	}
}

// ── Invites Page ──────────────────────────────────────────────────────────────
templ InvitesPage(vmodel InvitesPageVModel) {
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle("Invitations — "+vmodel.Org.Name())) {
		<div class="space-y-6">
			<div class="flex items-center justify-between">
				<h1 class="text-2xl font-semibold">Invitations</h1>
				@button.Button(button.Props{Href: common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/invites/new"))}) {
					@icon.Plus(icon.Props{Class: "h-4 w-4 mr-2"})
					Créer un lien
				}
			</div>
			if vmodel.NewURL != "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
					@alert.Description() {
						<div class="font-medium">Lien d'invitation créé</div>
						<div class="text-sm mt-1 font-mono break-all">{ vmodel.NewURL }</div>
					}
				}
			}
			if vmodel.Success != "" && vmodel.NewURL == "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
					@alert.Description() {
						Opération réussie.
					}
				}
			}
			if len(vmodel.Invites) == 0 {
				<div class="rounded-lg border p-6 text-center text-muted-foreground">Aucune invitation.</div>
			} else {
				@card.Card() {
					@card.Content() {
						@table.Table() {
							@table.Header() {
								@table.Head() {
									Email cible
								}
								@table.Head() {
									Rôle
								}
								@table.Head() {
									Utilisations
								}
								@table.Head() {
									Expire
								}
								@table.Head() {
									Statut
								}
								@table.Head() {
									Actions
								}
							}
							@table.Body() {
								for _, inv := range vmodel.Invites {
									@table.Row() {
										@table.Cell() {
											if inv.InviteeEmail() != nil {
												{ *inv.InviteeEmail() }
											} else {
												<span class="text-muted-foreground">Lien ouvert</span>
											}
										}
										@table.Cell() {
											{ inv.Role() }
										}
										@table.Cell() {
											if inv.MaxUses() != nil {
												{ fmt.Sprintf("%d / %d", inv.UsesCount(), *inv.MaxUses()) }
											} else {
												{ fmt.Sprintf("%d / ∞", inv.UsesCount()) }
											}
										}
										@table.Cell() {
											if inv.ExpiresAt() != nil {
												{ inv.ExpiresAt().Format("2006-01-02") }
											} else {
												Jamais
											}
										}
										@table.Cell() {
											if inv.RevokedAt() != nil {
												@badge.Badge(badge.Props{Variant: badge.VariantDestructive}) {
													Révoqué
												}
											} else {
												@badge.Badge(badge.Props{Variant: badge.VariantDefault}) {
													Actif
												}
											}
										}
										@table.Cell() {
											<div class="flex gap-2">
												<a href={ templ.SafeURL(vmodel.BaseURL + "/join/" + string(inv.ID())) } target="_blank" class="text-sm underline">Lien</a>
												if inv.RevokedAt() == nil {
													@button.Button(button.Props{
														Variant: button.VariantDestructive,
														Size:    button.SizeSm,
														Attributes: templ.Attributes{
															"type":     "button",
															"data-url": common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/invites/", string(inv.ID()))),
															"onclick":  "if(confirm('Révoquer cette invitation ?'))fetch(this.dataset.url,{method:'DELETE'}).then(r=>window.location.href=r.url)",
														},
													}) {
														Révoquer
													}
												}
											</div>
										}
									}
								}
							}
						}
					}
				}
			}
		</div>
	}
}

// ── Invite Form ───────────────────────────────────────────────────────────────
templ InviteForm(vmodel InviteFormVModel) {
	@common.AppLayout(vmodel.AppLayoutVModel, common.WithTitle("Créer une invitation")) {
		<div class="space-y-6">
			<h1 class="text-2xl font-semibold">Créer une invitation</h1>
			<form method="POST" action={ common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/admin/invites")) } class="space-y-4">
				<div class="space-y-2">
					<label class="text-sm font-medium">Email de l'invité (optionnel)</label>
					<p class="text-xs text-muted-foreground">Laisser vide pour un lien utilisable par n'importe qui.</p>
					@input.Input(input.Props{Name: "invitee_email", Type: "email", Placeholder: "utilisateur@exemple.com"})
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">Rôle</label>
					@selectbox.SelectBox(selectbox.Props{ID: "invite_role"}) {
						@selectbox.Trigger(selectbox.TriggerProps{Name: "role"}) {
							@selectbox.Value(selectbox.ValueProps{Placeholder: "Sélectionner un rôle"})
						}
						@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
							@selectbox.Group() {
								@selectbox.Item(selectbox.ItemProps{Value: "member", Selected: true}) {
									Membre
								}
								@selectbox.Item(selectbox.ItemProps{Value: "org:admin"}) {
									Admin organisation
								}
							}
						}
					}
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">Date d'expiration (optionnel)</label>
					@input.Input(input.Props{Name: "expires_at", Type: "date"})
				</div>
				<div class="space-y-2">
					<label class="text-sm font-medium">Nombre max d'utilisations (optionnel)</label>
					@input.Input(input.Props{Name: "max_uses", Type: "number", Placeholder: "1"})
				</div>
				@button.Button(button.Props{Type: "submit"}) {
					Créer le lien
				}
			</form>
		</div>
	}
}

// ── Org Usage Page ────────────────────────────────────────────────────────────
templ OrgUsagePage(vmodel OrgUsagePageVModel) {
	@common.AppLayout(
		vmodel.AppLayoutVModel,
		common.WithTitle("Usage — "+vmodel.Org.Name()),
		common.WithScripts(
			common.Script{Name: "chart", Component: chart.Script()},
			common.Script{Name: "popover", Component: popover.Script()},
			common.Script{Name: "selectbox", Component: selectbox.Script()},
		),
	) {
		<div class="space-y-6">
			<!-- Header: title + period selector + owner filter + CSV export -->
			<div class="flex items-center gap-4 flex-wrap">
				<h1 class="text-2xl font-semibold">Usage — { vmodel.Org.Name() }</h1>
				<div class="flex-1"></div>
				<form method="GET" class="flex items-center gap-2 flex-wrap">
					<label class="text-sm text-muted-foreground">Période :</label>
					@selectbox.SelectBox(selectbox.Props{ID: "range", Class: "w-40"}) {
						@selectbox.Trigger(selectbox.TriggerProps{
							Name:       "range",
							Attributes: templ.Attributes{"onchange": "this.form.submit()"},
						}) {
							@selectbox.Value(selectbox.ValueProps{Placeholder: "Période"})
						}
						@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
							@selectbox.Group() {
								for _, opt := range []struct{ Value, Label string }{
									{"1d", "Dernier jour"},
									{"7d", "7 derniers jours"},
									{"30d", "30 derniers jours"},
									{"90d", "3 derniers mois"},
									{"180d", "6 derniers mois"},
									{"365d", "Dernière année"},
								} {
									@selectbox.Item(selectbox.ItemProps{
										Value:    opt.Value,
										Selected: vmodel.Range == opt.Value || (vmodel.Range == "" && opt.Value == "7d"),
									}) {
										{ opt.Label }
									}
								}
							}
						}
					}
					if len(vmodel.Members) > 0 || len(vmodel.Applications) > 0 {
						<label class="text-sm text-muted-foreground">Owner :</label>
						@selectbox.SelectBox(selectbox.Props{Multiple: true, Class: "w-64"}) {
							@selectbox.Trigger(selectbox.TriggerProps{
								Name:              "owner",
								Multiple:          true,
								ShowPills:         false,
								SelectedCountText: "{n} sélectionnées",
							}) {
								@selectbox.Value(selectbox.ValueProps{
									Placeholder: "Tous",
									Multiple:    true,
								})
							}
							@selectbox.Content(selectbox.ContentProps{
								SearchPlaceholder: "Rechercher...",
							}) {
								@selectbox.Group() {
									for _, m := range vmodel.Members {
										if m.User() != nil {
											@selectbox.Item(selectbox.ItemProps{
												Value:    string(m.User().ID()),
												Selected: slices.Contains(vmodel.OwnerFilter, string(m.User().ID())),
											}) {
												<span class="flex items-center gap-2">
													@icon.User(icon.Props{Class: "h-4 w-4 text-muted-foreground"})
													{ m.User().DisplayName() }
												</span>
											}
										}
									}
								}
								@selectbox.Group() {
									for _, app := range vmodel.Applications {
										@selectbox.Item(selectbox.ItemProps{
											Value:    string(app.ID()),
											Selected: slices.Contains(vmodel.OwnerFilter, string(app.ID())),
										}) {
											<span class="flex items-center gap-2">
												@icon.ExternalLink(icon.Props{Class: "h-4 w-4 text-muted-foreground"})
												{ app.Name() }
											</span>
										}
									}
								}
							}
						}
					}
					@button.Button(button.Props{Type: "submit", Variant: button.VariantOutline, Size: button.SizeSm}) {
						Filtrer
					}
				</form>
				@button.Button(button.Props{
					Variant: button.VariantOutline,
					Size:    button.SizeSm,
					Href:    common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/usage"), common.WithValues("range", vmodel.Range, "owner", strings.Join(vmodel.OwnerFilter, ","), "format", "csv")),
				}) {
					@icon.Download(icon.Props{Class: "h-4 w-4"})
					Export CSV
				}
			</div>
			<!-- Org quota card -->
			if vmodel.OrgQuota != nil {
				{{
					var budget *int64
					var spent int64
					periodLabel := "mensuel"
					switch {
					case vmodel.OrgQuota.MonthlyBudget() != nil:
						budget = vmodel.OrgQuota.MonthlyBudget()
						spent = vmodel.MonthlyCost
						periodLabel = "mensuel"
					case vmodel.OrgQuota.YearlyBudget() != nil:
						budget = vmodel.OrgQuota.YearlyBudget()
						spent = vmodel.YearlyCost
						periodLabel = "annuel"
					case vmodel.OrgQuota.DailyBudget() != nil:
						budget = vmodel.OrgQuota.DailyBudget()
						spent = vmodel.DailyCost
						periodLabel = "journalier"
					}
					pct := common.UsagePercent(spent, budget)
					barColor := "var(--chart-2)"
					badgeVariant := badge.VariantSecondary
					if pct > 90 {
						barColor = "var(--destructive)"
						badgeVariant = badge.VariantDestructive
					} else if pct > 70 {
						barColor = "var(--chart-3)"
					}
				}}
				@card.Card() {
					@card.Content() {
						<div class="flex items-start justify-between gap-2 mb-3">
							<div>
								<div class="font-semibold">Quota</div>
								<div class="text-xs text-muted-foreground mt-1">
									if budget != nil {
										{ common.FormatCost(spent, vmodel.Currency) } / { common.FormatCost(*budget, vmodel.Currency) } · { fmt.Sprintf("%d%% du quota %s", pct, periodLabel) }
									} else {
										Aucun quota défini (utilisation illimitée)
									}
								</div>
							</div>
							if budget != nil {
								@badge.Badge(badge.Props{Variant: badgeVariant}) {
									{ fmt.Sprintf("%d%%", pct) }
								}
							} else {
								@badge.Badge(badge.Props{Variant: badge.VariantOutline}) {
									Illimité
								}
							}
						</div>
						if budget != nil {
							<div class="h-1.5 rounded-full bg-muted overflow-hidden">
								<div class="h-full rounded-full" style={ fmt.Sprintf("width: %d%%; background: %s", pct, barColor) }></div>
							</div>
						}
						<div class="grid grid-cols-3 gap-4 mt-3.5 text-xs">
							<div>
								<div class="text-muted-foreground">Aujourd'hui</div>
								<div class="font-semibold mt-0.5">{ common.FormatCost(vmodel.DailyCost, vmodel.Currency) }</div>
							</div>
							<div>
								<div class="text-muted-foreground">Ce mois</div>
								<div class="font-semibold mt-0.5">{ common.FormatCost(vmodel.MonthlyCost, vmodel.Currency) }</div>
							</div>
							<div>
								<div class="text-muted-foreground">Cette année</div>
								<div class="font-semibold mt-0.5">{ common.FormatCost(vmodel.YearlyCost, vmodel.Currency) }</div>
							</div>
						</div>
					}
				}
			}
			<!-- Summary cards -->
			if vmodel.Aggregate != nil {
				<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4">
					@card.Card() {
						@card.Content() {
							<div class="flex items-center gap-2 text-sm font-medium text-muted-foreground">
								@icon.Send(icon.Props{Class: "h-4 w-4 text-primary"})
								Requêtes
							</div>
							<p class="text-2xl font-bold mt-2">{ fmt.Sprintf("%d", vmodel.Aggregate.TotalRequests) }</p>
						}
					}
					@card.Card() {
						@card.Content() {
							<div class="flex items-center gap-2 text-sm font-medium text-muted-foreground">
								@icon.Coins(icon.Props{Class: "h-4 w-4", Color: "var(--chart-3)"})
								Tokens
							</div>
							<p class="text-2xl font-bold mt-2">{ fmt.Sprintf("%d", vmodel.Aggregate.TotalTokens) }</p>
							if vmodel.Aggregate.CachedTokens > 0 && vmodel.Aggregate.PromptTokens > 0 {
								<p class="text-xs text-muted-foreground mt-1">
									{ fmt.Sprintf("dont %d en cache (%.0f%% des tokens prompt)", vmodel.Aggregate.CachedTokens, float64(vmodel.Aggregate.CachedTokens)/float64(vmodel.Aggregate.PromptTokens)*100) }
								</p>
							}
						}
					}
					@card.Card() {
						@card.Content() {
							<div class="flex items-center gap-2 text-sm font-medium text-muted-foreground">
								@icon.Euro(icon.Props{Class: "h-4 w-4", Color: "var(--chart-2)"})
								Coût total
							</div>
							if vmodel.Aggregate.TotalCost == 0 {
								<p class="text-2xl font-bold mt-2">—</p>
							} else {
								<p class="text-2xl font-bold mt-2">{ common.FormatCost(vmodel.Aggregate.TotalCost, vmodel.Aggregate.Currency) }</p>
							}
						}
					}
					if vmodel.TotalEnergyWh > 0 {
						@card.Card() {
							@card.Content() {
								<div class="flex items-center gap-2 text-sm font-medium text-muted-foreground">
									@icon.Zap(icon.Props{Class: "h-4 w-4", Color: "var(--chart-4)"})
									Énergie
								</div>
								<div class="flex items-center gap-2 mt-2">
									<p class="text-2xl font-bold">{ common.FormatEnergyWh(vmodel.TotalEnergyWh) }</p>
									{{ energyMessage := common.FormatEnergyToHuman(vmodel.TotalEnergyWh) }}
									if energyMessage != "" {
										{{ tooltipID := "energy-tooltip-" + fmt.Sprintf("%.0f", vmodel.TotalEnergyWh) }}
										@tooltip.Tooltip() {
											@tooltip.Trigger(tooltip.TriggerProps{For: tooltipID, Class: "cursor-help text-muted-foreground hover:text-foreground"}) {
												@icon.CircleQuestionMark(icon.Props{Class: "h-5 w-5"})
											}
											@tooltip.Content(tooltip.ContentProps{ID: tooltipID, Position: tooltip.PositionRight, Class: "max-w-xs"}) {
												<p>{ energyMessage }</p>
											}
										}
									}
								</div>
								<p class="text-xs text-muted-foreground mt-1">estimation ±facteur ×3-5</p>
							}
						}
					}
					if vmodel.TotalCO2GramsMid > 0 {
						@card.Card() {
							@card.Content() {
								<div class="flex items-center gap-2 text-sm font-medium text-muted-foreground">
									@icon.Leaf(icon.Props{Class: "h-4 w-4", Color: "oklch(0.55 0.15 140)"})
									CO₂
								</div>
								<div class="flex items-center gap-2 mt-2">
									<p class="text-2xl font-bold">{ common.FormatCO2Grams(vmodel.TotalCO2GramsMid) }</p>
									{{ co2Message := common.FormatCO2ToCarKilometers(vmodel.TotalCO2GramsMid) }}
									if co2Message != "" {
										{{ tooltipID := "co2-tooltip-" + fmt.Sprintf("%.0f", vmodel.TotalCO2GramsMid) }}
										@tooltip.Tooltip() {
											@tooltip.Trigger(tooltip.TriggerProps{For: tooltipID, Class: "cursor-help text-muted-foreground hover:text-foreground"}) {
												@icon.CircleQuestionMark(icon.Props{Class: "h-5 w-5"})
											}
											@tooltip.Content(tooltip.ContentProps{ID: tooltipID, Position: tooltip.PositionRight, Class: "max-w-xs"}) {
												<p>{ co2Message }</p>
											}
										}
									}
								</div>
								<p class="text-xs text-muted-foreground mt-1">estimation mix monde, ±facteur ×3-5</p>
							}
						}
					}
				</div>
			}
			<!-- Charts: cost per day, model breakdown, per user, per provider -->
			if len(vmodel.ChartPerDay) > 0 || len(vmodel.ChartSharesPerModel) > 0 || len(vmodel.ChartPerUser) > 0 || len(vmodel.ChartPerProvider) > 0 {
				{{ trueVal := true }}
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
					if len(vmodel.ChartPerDay) > 0 {
						@card.Card() {
							@card.Header() {
								@card.Title() {
									Coût par jour
								}
							}
							@card.Content() {
								@chart.Chart(chart.Props{
									Variant:     chart.VariantBar,
									ShowXLabels: true,
									ShowYLabels: true,
									ShowYGrid:   true,
									ShowLegend:  false,
									BeginAtZero: &trueVal,
									Class:       "h-64",
									Data: chart.Data{
										Labels: common.ChartLabels(vmodel.ChartPerDay),
										Datasets: []chart.Dataset{{
											Label:           vmodel.Currency,
											Data:            common.ChartValues(vmodel.ChartPerDay),
											BackgroundColor: "rgba(99,102,241,0.8)",
										}},
									},
								})
							}
						}
					}
					if len(vmodel.ChartSharesPerModel) > 0 {
						@card.Card() {
							@card.Header() {
								@card.Title() {
									Répartition par modèle
								}
							}
							@card.Content() {
								for _, share := range vmodel.ChartSharesPerModel {
									<div class="flex items-center gap-2.5 py-1.5">
										<span class="w-2.5 h-2.5 rounded-xs shrink-0" style={ fmt.Sprintf("background: %s", share.Color) }></span>
										<span class="text-sm font-mono text-foreground w-28 overflow-hidden text-ellipsis whitespace-nowrap">{ share.Label }</span>
										<div class="flex-1 h-1.5 rounded-full bg-muted overflow-hidden">
											<div class="h-full rounded-full" style={ fmt.Sprintf("width: %d%%; background: %s", share.Pct, share.Color) }></div>
										</div>
										<span class="text-xs text-muted-foreground w-10 text-right">{ fmt.Sprintf("%d%%", share.Pct) }</span>
									</div>
								}
							}
						}
					}
					if len(vmodel.ChartPerUser) > 0 {
						@card.Card() {
							@card.Header() {
								@card.Title() {
									Coût par utilisateur
								}
							}
							@card.Content() {
								@chart.Chart(chart.Props{
									Variant:     chart.VariantBar,
									ShowXLabels: true,
									ShowYLabels: true,
									ShowYGrid:   true,
									ShowLegend:  false,
									BeginAtZero: &trueVal,
									Class:       "h-64",
									Data: chart.Data{
										Labels: common.ChartLabels(vmodel.ChartPerUser),
										Datasets: []chart.Dataset{{
											Label:           vmodel.Currency,
											Data:            common.ChartValues(vmodel.ChartPerUser),
											BackgroundColor: "rgba(245,158,11,0.8)",
										}},
									},
								})
							}
						}
					}
					if len(vmodel.ChartPerProvider) > 0 {
						@card.Card() {
							@card.Header() {
								@card.Title() {
									Coût par fournisseur
								}
							}
							@card.Content() {
								@chart.Chart(chart.Props{
									Variant:     chart.VariantBar,
									ShowXLabels: true,
									ShowYLabels: true,
									ShowYGrid:   true,
									ShowLegend:  false,
									BeginAtZero: &trueVal,
									Class:       "h-64",
									Data: chart.Data{
										Labels: common.ChartLabels(vmodel.ChartPerProvider),
										Datasets: []chart.Dataset{{
											Label:           vmodel.Currency,
											Data:            common.ChartValues(vmodel.ChartPerProvider),
											BackgroundColor: "rgba(168,85,247,0.8)",
										}},
									},
								})
							}
						}
					}
				</div>
			}
			<!-- Usage records table -->
			if len(vmodel.Records) > 0 {
				@card.Card() {
					@card.Content() {
						@table.Table() {
							@table.Header() {
								@table.Head() {
									Date
								}
								@table.Head() {
									Utilisateur / Application
								}
								@table.Head() {
									Modèle
								}
								@table.Head() {
									Tokens (in/out)
								}
								@table.Head() {
									Coût
								}
								@table.Head() {
									Énergie
								}
								@table.Head() {
									CO₂
								}
							}
							@table.Body() {
								for _, dr := range vmodel.Records {
									@table.Row() {
										@table.Cell() {
											{ dr.Record.CreatedAt().Format("2006-01-02 15:04") }
										}
										@table.Cell() {
											{ displayOwner(vmodel.Users, vmodel.ApplicationsMap, dr.Record) }
										}
										@table.Cell() {
											<span class="font-mono">{ dr.DisplayModelName }</span>
										}
										@table.Cell() {
											<div class="flex items-center gap-1.5">
												{ fmt.Sprintf("%d / %d", dr.Record.PromptTokens(), dr.Record.CompletionTokens()) }
												if dr.Record.CachedTokens() > 0 {
													<span
														title={ fmt.Sprintf("%d tokens en cache", dr.Record.CachedTokens()) }
														class="cursor-help text-muted-foreground"
													>
														@icon.DatabaseZap(icon.Props{Class: "h-3.5 w-3.5"})
													</span>
												}
											</div>
										}
										@table.Cell() {
											if dr.Converted {
												<span
													title={ common.FormatCost(dr.Record.Cost(), dr.Record.Currency()) }
													class="cursor-help underline decoration-dotted"
												>
													{ common.FormatCost(dr.DisplayCost, dr.DisplayCurrency) }
												</span>
											} else {
												{ common.FormatCost(dr.DisplayCost, dr.DisplayCurrency) }
											}
										}
										@table.Cell() {
											if dr.EnergyWh > 0 {
												<span
													title={ fmt.Sprintf("min: %s / max: %s", common.FormatEnergyWh(dr.EnergyLowWh), common.FormatEnergyWh(dr.EnergyHighWh)) }
													class="cursor-help underline decoration-dotted"
												>
													{ common.FormatEnergyWh(dr.EnergyWh) }
												</span>
											} else {
												—
											}
										}
										@table.Cell() {
											if dr.CO2GramsMid > 0 {
												<span
													title={ fmt.Sprintf("CO₂ France : %s / monde : %s / charbon : %s", common.FormatCO2Grams(dr.CO2GramsMin), common.FormatCO2Grams(dr.CO2GramsMid), common.FormatCO2Grams(dr.CO2GramsMax)) }
													class="cursor-help underline decoration-dotted text-muted-foreground"
												>
													{ common.FormatCO2Grams(dr.CO2GramsMid) }
												</span>
											} else {
												—
											}
										}
									}
								}
							}
						}
					}
				}
				@pagination.Pagination() {
					@pagination.Content() {
						@pagination.Previous(pagination.PreviousProps{
							Href:     common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/usage"), common.WithValues("range", vmodel.Range, "page", fmt.Sprintf("%d", vmodel.Page-1), "owner", strings.Join(vmodel.OwnerFilter, ","))),
							Disabled: vmodel.Page <= 1,
							Label:    "Précédent",
						})
						@pagination.Next(pagination.NextProps{
							Href:     common.BaseURLString(ctx, common.WithPath("/orgs/", vmodel.Org.Slug(), "/usage"), common.WithValues("range", vmodel.Range, "page", fmt.Sprintf("%d", vmodel.Page+1), "owner", strings.Join(vmodel.OwnerFilter, ","))),
							Disabled: !vmodel.HasNext,
							Label:    "Suivant",
						})
					}
				}
			}
		</div>
	}
}

// ── Helpers ───────────────────────────────────────────────────────────────────

func displayOwner(users map[model.UserID]model.User, apps map[model.ApplicationID]model.Application, rec model.UsageRecord) string {
	// Check if this is an Application record (has non-empty ApplicationID)
	appID := rec.ApplicationID()
	if appID != "" {
		if app, ok := apps[appID]; ok {
			return app.Name()
		}
		return string(appID)
	}
	// Otherwise it's a User record
	uid := rec.UserID()
	if u, ok := users[uid]; ok {
		return u.DisplayName()
	}
	return string(uid)
}

// formatCostRate formats a pricing rate stored as microcents per 1K tokens,
// displaying it as dollars per million tokens (industry standard).
func formatCostRate(v int64, currency string) string {
	return fmt.Sprintf("%.4f%s/1M", float64(v)/1_000, common.CurrencySymbol(currency))
}

func fmtInt(v int64) string {
	if v == 0 {
		return ""
	}
	return fmt.Sprintf("%d", v)
}

func formatCostField(v int64) string {
	// v is microcents/1K tokens; return dollars per 1M tokens for the form field
	return fmt.Sprintf("%.6f", float64(v)/1_000)
}

// formatActiveParamsBillions converts raw param count to billions for display in the form.
func formatActiveParamsBillions(v int64) string {
	if v <= 0 {
		return ""
	}
	return strconv.FormatFloat(float64(v)/1e9, 'f', -1, 64)
}

func formatBudgetField(v int64) string {
	// v is microcents; convert to the display unit (e.g. EUR/USD) with full precision.
	// Use 'f' format with prec=-1 so strconv uses the minimum number of digits needed
	// to represent the value exactly, avoiding both truncation ("0.00" for 100 µ¢)
	// and unnecessary trailing zeros ("100.000000" for 100_000_000 µ¢).
	return strconv.FormatFloat(float64(v)/1_000_000, 'f', -1, 64)
}

// durationValue returns the numeric component of d in its natural unit (minutes,
// seconds, or milliseconds). Returns "" for a zero duration.
func durationValue(d time.Duration) string {
	if d == 0 {
		return ""
	}
	if d%time.Minute == 0 {
		return fmt.Sprintf("%d", int64(d/time.Minute))
	}
	if d%time.Second == 0 {
		return fmt.Sprintf("%d", int64(d/time.Second))
	}
	return fmt.Sprintf("%d", int64(d/time.Millisecond))
}

// durationUnit returns "min", "s", or "ms" depending on the most coarse
// whole unit that can represent d. Returns "s" for a zero duration.
func durationUnit(d time.Duration) string {
	if d != 0 && d%time.Minute == 0 {
		return "min"
	}
	if d != 0 && d%time.Second == 0 {
		return "s"
	}
	if d != 0 {
		return "ms"
	}
	return "s"
}
