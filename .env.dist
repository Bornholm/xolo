XOLO_SECRET_KEY="" # Generate it with "openssl rand -hex 32"

XOLO_LOGGER_LEVEL=-4
XOLO_LOGGER_DEBUG=true

XOLO_HTTP_SESSION_KEYS=abcdefghijklmnopqrstuvwxyz000002
XOLO_HTTP_BASE_URL=http://localhost:3002

XOLO_HTTP_AUTHN_DEFAULT_ADMINS="<your_email>"

XOLO_HTTP_AUTHN_PROVIDERS_GITEA_KEY=
XOLO_HTTP_AUTHN_PROVIDERS_GITEA_SECRET=
XOLO_HTTP_AUTHN_PROVIDERS_GITEA_LABEL="My Gitea Identity Provider"
XOLO_HTTP_AUTHN_PROVIDERS_GITEA_AUTH_URL=https://gitea-server/login/oauth/authorize
XOLO_HTTP_AUTHN_PROVIDERS_GITEA_TOKEN_URL=https://gitea-server/login/oauth/access_token
XOLO_HTTP_AUTHN_PROVIDERS_GITEA_PROFILE_URL=https://gitea-server/login/oauth/userinfo
XOLO_HTTP_AUTHN_PROVIDERS_GITEA_SCOPES=openid,email

XOLO_HTTP_AUTHN_PROVIDERS_GOOGLE_KEY=
XOLO_HTTP_AUTHN_PROVIDERS_GOOGLE_SECRET=

XOLO_HTTP_AUTHN_PROVIDERS_GITHUB_KEY=
XOLO_HTTP_AUTHN_PROVIDERS_GITHUB_SECRET=
XOLO_HTTP_AUTHN_PROVIDERS_GITHUB_SCOPES=openid,user

# Multiple named OIDC providers (login + API opaque-token validation).
# List their IDs, then configure each under _<ID>_ (ID upper-cased).
# XOLO_HTTP_AUTHN_OIDC_PROVIDERS=auth0,keycloak
# XOLO_HTTP_AUTHN_OIDC_PROVIDER_AUTH0_DISCOVERY_URL=https://tenant.eu.auth0.com/.well-known/openid-configuration
# XOLO_HTTP_AUTHN_OIDC_PROVIDER_AUTH0_KEY=
# XOLO_HTTP_AUTHN_OIDC_PROVIDER_AUTH0_SECRET=
# XOLO_HTTP_AUTHN_OIDC_PROVIDER_AUTH0_LABEL="Auth0"
# XOLO_HTTP_AUTHN_OIDC_PROVIDER_AUTH0_ICON=log-in
# XOLO_HTTP_AUTHN_OIDC_PROVIDER_AUTH0_SCOPES=openid,profile,email
# Enforced only on the introspection path (ignored when validated via userinfo):
# XOLO_HTTP_AUTHN_OIDC_PROVIDER_AUTH0_REQUIRED_AUDIENCE=<api-identifier>
# XOLO_HTTP_AUTHN_OIDC_PROVIDER_AUTH0_REQUIRED_SCOPE=

# Validate incoming opaque OAuth2 access tokens on the API (introspection when
# the provider exposes it, otherwise the OIDC userinfo endpoint).
# XOLO_HTTP_AUTHN_OAUTH2TOKEN_ENABLED=true
# XOLO_HTTP_AUTHN_OAUTH2TOKEN_CACHE_TTL=60s
# XOLO_HTTP_AUTHN_OAUTH2TOKEN_CACHE_SIZE=1024

XOLO_PLUGINS_DIR=bin/plugins