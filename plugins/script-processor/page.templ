package main

import (
	"fmt"

	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/alert"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/button"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/card"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/label"
)

var inputPortTypes = []string{"number", "string", "boolean", "request", "response"}
var outputPortTypes = []string{"number", "string", "boolean"}

templ page(pd uiPageData) {
	<!DOCTYPE html>
	<html class="dark">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<base href={ pd.BasePath }/>
			<link rel="stylesheet" href="/assets/templui.css"/>
		</head>
		<body class="bg-background text-foreground min-h-screen p-4 space-y-4">
			<h1 class="text-lg font-semibold">Processeur de requête scripté</h1>
			<p class="text-sm text-muted-foreground">
				Script <a href="https://github.com/d5/tengo" target="_blank" class="underline">Tengo</a>
				exécuté avant chaque appel LLM. La fonction exportée reçoit un <code class="font-mono text-xs">ctx</code> structuré
				et retourne un map <code class="font-mono text-xs">&#123;outputs: &#123;…&#125;, messages: […]&#125;</code>.
			</p>

			if pd.Success {
				@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
					@alert.Description() { Configuration sauvegardée avec succès. }
				}
			}

			<form id="main-form" method="POST" action="api/config" class="space-y-6">
				<!-- Inputs -->
				@card.Card() {
					@card.Header() {
						<div class="flex items-center justify-between">
							@card.Title() { Entrées (ports d'entrée) }
							@button.Button(button.Props{
								Type:       button.TypeSubmit,
								Variant:    button.VariantOutline,
								Size:       button.SizeSm,
								Attributes: templ.Attributes{"formaction": "api/inputs/add"},
							}) {
								+ Ajouter une entrée
							}
						</div>
					}
					@card.Content() {
						if len(pd.Config.Inputs) == 0 {
							<p class="text-sm text-muted-foreground italic text-center py-2">
								Aucune entrée — accessibles via <code class="font-mono text-xs">ctx.inputs["nom"]</code>
							</p>
						} else {
							<div class="space-y-2">
								for i, p := range pd.Config.Inputs {
									@portRow("input", i, p, inputPortTypes)
								}
							</div>
						}
					}
				}

				<!-- Outputs -->
				@card.Card() {
					@card.Header() {
						<div class="flex items-center justify-between">
							@card.Title() { Sorties (ports de sortie) }
							@button.Button(button.Props{
								Type:       button.TypeSubmit,
								Variant:    button.VariantOutline,
								Size:       button.SizeSm,
								Attributes: templ.Attributes{"formaction": "api/outputs/add"},
							}) {
								+ Ajouter une sortie
							}
						</div>
					}
					@card.Content() {
						if len(pd.Config.Outputs) == 0 {
							<p class="text-sm text-muted-foreground italic text-center py-2">
								Aucune sortie — retournées via <code class="font-mono text-xs">&#123;outputs: &#123;nom: valeur&#125;&#125;</code>
							</p>
						} else {
							<div class="space-y-2">
								for i, p := range pd.Config.Outputs {
									@portRow("output", i, p, outputPortTypes)
								}
							</div>
						}
					}
				}

				<!-- Script -->
				@card.Card() {
					@card.Header() {
						@card.Title() { Script Tengo }
					}
					@card.Content() {
						<div class="space-y-1">
							@label.Label(label.Props{For: "script"}) {
								Module Tengo exportant <code class="font-mono text-xs">func(ctx)</code> → <code class="font-mono text-xs">&#123;outputs, messages&#125;</code>
							}
							<textarea
								id="script"
								name="script"
								rows="16"
								class="flex w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm font-mono shadow-xs placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
								placeholder={ scriptPlaceholder }
							>{ pd.Config.Script }</textarea>
							<div class="text-xs text-muted-foreground space-y-1">
								<p>
									<strong>ctx.request</strong> — corps complet de la requête (<code class="font-mono">model</code>, <code class="font-mono">temperature</code>, <code class="font-mono">messages</code>…)
								</p>
								<p>
									<strong>ctx.inputs["nom"]</strong> — valeur du port d'entrée
								</p>
								<p>
									Retourner <code class="font-mono">&#123;messages: […]&#125;</code> pour modifier les messages LLM (clé réservée).
								</p>
								<p>
									Modules disponibles : <code class="font-mono">json</code>, <code class="font-mono">math</code>, <code class="font-mono">text</code>, <code class="font-mono">rand</code>, <code class="font-mono">times</code>.
								</p>
							</div>
						</div>
					}
				}

				<div class="flex justify-end">
					@button.Button(button.Props{Type: button.TypeSubmit}) {
						Sauvegarder
					}
				</div>
			</form>
		</body>
	</html>
}

const scriptPlaceholder = `export func(ctx) {
    // Routage basé sur power_level
    model := ctx.inputs["model_leger"]
    if ctx.inputs["power_level"] > 0.75 {
        model = ctx.inputs["model_puissant"]
    }
    return { outputs: { model_name: model } }

    // Pour modifier les messages :
    // sys := {role: "system", content: "Réponds en français."}
    // return { outputs: {...}, messages: [sys] + ctx.request["messages"] }
}`

templ portRow(prefix string, idx int, p PortDef, types []string) {
	<div class="flex items-center gap-2">
		<input
			type="text"
			name={ fmt.Sprintf("%s_%d_name", prefix, idx) }
			value={ p.Name }
			placeholder="nom"
			class="flex-1 h-8 rounded-md border border-input bg-transparent px-2 text-sm font-mono focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
		/>
		<select
			name={ fmt.Sprintf("%s_%d_type", prefix, idx) }
			class="h-8 rounded-md border border-input bg-background px-2 text-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
		>
			for _, t := range types {
				<option value={ t } if p.PortType == t { selected }>{ t }</option>
			}
		</select>
		@button.Button(button.Props{
			Type:    button.TypeSubmit,
			Variant: button.VariantDestructive,
			Size:    button.SizeIcon,
			Attributes: templ.Attributes{
				"formaction": fmt.Sprintf("api/%ss/%d/delete", prefix, idx),
				"title":      "Supprimer",
			},
		}) {
			✕
		}
	</div>
}
