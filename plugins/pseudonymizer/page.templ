package main

import (
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/alert"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/badge"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/button"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/card"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/input"
	"github.com/bornholm/xolo/internal/http/handler/webui/templui/component/label"
)

// page renders the pseudonymizer plugin configuration UI.
templ page(pd uiPageData) {
	<!DOCTYPE html>
	<html class="dark">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<base href={ pd.BasePath }/>
			<link rel="stylesheet" href="/assets/templui.css"/>
		</head>
		<body class="bg-background text-foreground min-h-screen p-4 space-y-4">
			<h1 class="text-lg font-semibold">Pseudonymisation</h1>
			<p class="text-sm text-muted-foreground">
				Anonymise automatiquement les entités nommées (personnes, lieux, organisations…) dans les
				messages avant transmission au LLM, et rétablit les données originales dans la réponse.
			</p>

			if pd.Success {
				@alert.Alert(alert.Props{Variant: alert.VariantDefault}) {
					@alert.Description() {
						Configuration sauvegardée avec succès.
					}
				}
			}
			if pd.Error != "" {
				@alert.Alert(alert.Props{Variant: alert.VariantDestructive}) {
					@alert.Description() {
						{ pd.Error }
					}
				}
			}

			<!-- Model status -->
			@card.Card() {
				@card.Header() {
					@card.Title() { Modèles NER disponibles }
				}
				@card.Content() {
					if len(pd.ModelStatus) == 0 {
						<p class="text-sm text-muted-foreground italic">
							Impossible de lister les modèles disponibles (pas de connexion réseau ou cache vide).
						</p>
					} else {
						<div class="flex flex-wrap gap-2">
							for _, ms := range pd.ModelStatus {
								@modelStatusBadge(ms)
							}
						</div>
						<p class="text-xs text-muted-foreground mt-2">
							Les modèles non encore en cache seront téléchargés automatiquement lors du premier appel.
						</p>
					}
				}
			}

			<form method="POST" action="api/config" class="space-y-4">
				<!-- Language & Strategy -->
				@card.Card() {
					@card.Header() {
						@card.Title() { Anonymisation }
					}
					@card.Content() {
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
							<div class="space-y-1">
								@label.Label(label.Props{For: "language"}) { Langue }
								<select
									id="language"
									name="language"
									class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
								>
									<option value="auto" if pd.Config.Language == LanguageAuto { selected }>Détection automatique</option>
									for _, lang := range pd.Languages {
										<option value={ lang } if pd.Config.Language == lang { selected }>{ languageLabel(lang) }</option>
									}
								</select>
								<p class="text-xs text-muted-foreground">
									En détection automatique, la langue est déterminée à chaque requête à partir des
									messages, parmi les modèles disponibles.
								</p>
							</div>
							<div class="space-y-1">
								@label.Label(label.Props{For: "fallback_language"}) { Langue de repli }
								<select
									id="fallback_language"
									name="fallback_language"
									class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
								>
									for _, lang := range pd.Languages {
										<option value={ lang } if pd.Config.FallbackLanguage == lang { selected }>{ languageLabel(lang) }</option>
									}
								</select>
								<p class="text-xs text-muted-foreground">
									Utilisée lorsque la détection n'est pas fiable (message trop court, langue non supportée).
								</p>
							</div>
							<div class="space-y-1">
								@label.Label(label.Props{For: "strategy"}) { Stratégie }
								<select
									id="strategy"
									name="strategy"
									class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-xs focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
								>
									<option value="tag" if pd.Config.Strategy == "tag" { selected }>Tag — [PERSON_1]</option>
									<option value="redact" if pd.Config.Strategy == "redact" { selected }>Redact — ████</option>
									<option value="hash" if pd.Config.Strategy == "hash" { selected }>Hash — [PER_a1b2c3]</option>
									<option value="consistent" if pd.Config.Strategy == "consistent" { selected }>Consistent — numérotation stable</option>
								</select>
							</div>
						</div>
					}
				}

				<!-- Filters -->
				@card.Card() {
					@card.Header() {
						@card.Title() { Filtres NER }
					}
					@card.Content() {
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
							<div class="space-y-1">
								@label.Label(label.Props{For: "min_confidence"}) { Confiance minimale (0.0 – 1.0) }
								@input.Input(input.Props{
									ID:          "min_confidence",
									Name:        "min_confidence",
									Type:        "number",
									Value:       formatFloat(pd.Config.MinConfidence),
									Placeholder: "0",
									Attributes:  templ.Attributes{"step": "0.05", "min": "0", "max": "1"},
								})
							</div>
							<div class="space-y-1">
								@label.Label(label.Props{For: "max_tokens"}) { Tokens max par entité (0 = illimité) }
								@input.Input(input.Props{
									ID:          "max_tokens",
									Name:        "max_tokens",
									Type:        "number",
									Value:       formatInt(pd.Config.MaxTokens),
									Placeholder: "0",
									Attributes:  templ.Attributes{"min": "0"},
								})
							</div>
						</div>
					}
				}

				<!-- Options -->
				@card.Card() {
					@card.Header() {
						@card.Title() { Options }
					}
					@card.Content() {
						<div class="space-y-3">
							@checkboxRow("builtin_regex_patterns", "Patterns regex intégrés", "Détecte EMAIL, IPV4/6, IBAN, SIRET, SIREN, PHONE automatiquement.", pd.Config.BuiltinRegexPatterns)
							@checkboxRow("builtin_secret_patterns", "Patterns secrets intégrés", "Détecte JWT, clés API (OpenAI, AWS, GitHub, Slack…) automatiquement.", pd.Config.BuiltinSecretPatterns)
							@checkboxRow("first_name_reclassify", "Reclassification des prénoms", "Reclasse les entités LOC d'un seul token en PER si le token est un prénom connu.", pd.Config.FirstNameReclassify)
							@checkboxRow("merge", "Fusion des entités adjacentes", "Fusionne les entités adjacentes de même type (prénom + nom de famille).", pd.Config.Merge)
							@checkboxRow("name_completion", "Complétion des noms", "Complète les entités PER partielles avec le token de nom de famille adjacent.", pd.Config.NameCompletion)
							@checkboxRow("inject_instruction", "Instruction de préservation des jetons", "Ajoute une instruction système (dans la langue détectée) demandant au LLM de recopier les jetons de substitution sans les modifier. Ignoré pour la stratégie « redact ».", pd.Config.InjectInstruction)
						</div>
					}
				}

				<!-- Model store -->
				@card.Card() {
					@card.Header() {
						@card.Title() { Stockage des modèles }
					}
					@card.Content() {
						<div class="space-y-3">
							<div class="space-y-1">
								@label.Label(label.Props{For: "cache_dir"}) { Répertoire de cache }
								@input.Input(input.Props{
									ID:          "cache_dir",
									Name:        "cache_dir",
									Value:       pd.Config.CacheDir,
									Placeholder: "Défaut : répertoire cache système",
								})
							</div>
							<div class="space-y-1">
								@label.Label(label.Props{For: "manifest_url"}) { URL du manifest }
								@input.Input(input.Props{
									ID:          "manifest_url",
									Name:        "manifest_url",
									Value:       pd.Config.ManifestURL,
									Placeholder: "Défaut : dépôt officiel go-anon",
								})
							</div>
							@checkboxRow("offline", "Mode hors-ligne", "Désactive les téléchargements réseau. Nécessite des modèles déjà en cache.", pd.Config.Offline)
						</div>
					}
				}

				<!-- Save -->
				<div class="flex justify-end">
					@button.Button(button.Props{Type: button.TypeSubmit}) {
						Sauvegarder
					}
				</div>
			</form>
		</body>
	</html>
}

templ modelStatusBadge(ms modelStatusEntry) {
	if ms.Cached {
		@badge.Badge(badge.Props{}) {
			✓ { ms.Lang }
		}
	} else {
		@badge.Badge(badge.Props{Variant: badge.VariantOutline}) {
			○ { ms.Lang }
		}
	}
}

templ checkboxRow(name, title, description string, checked bool) {
	<div class="flex items-start gap-3">
		<input
			type="checkbox"
			id={ name }
			name={ name }
			class="mt-0.5 h-4 w-4 rounded border border-input"
			if checked { checked }
		/>
		<div class="space-y-0.5">
			@label.Label(label.Props{For: name}) { { title } }
			<p class="text-xs text-muted-foreground">{ description }</p>
		</div>
	</div>
}
